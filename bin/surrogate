#!/usr/bin/env bash
set -euo pipefail

SURROGATE_TMP="/tmp"
BRIDGE_PREFIX="_surr_"
ALIAS_FILE="${SURROGATE_TMP}/surrogate-aliases"
AUDIT_FILE="${SURROGATE_AUDIT_FILE:-${SURROGATE_TMP}/surrogate-audit.jsonl}"
SURROGATE_LABEL="${SURROGATE_LABEL:-on}"  # on | off | verbose
SURROGATE_TYPE_ENTER_DELAY_SECS="${SURROGATE_TYPE_ENTER_DELAY_SECS:-0.02}"
SURROGATE_TYPE_POSTCHECK_SECS="${SURROGATE_TYPE_POSTCHECK_SECS:-0.15}"

# --- helpers (needed early) ---

die() { echo "surrogate: error: $*" >&2; exit 1; }
warn() { echo "surrogate: warning: $*" >&2; }

require_int() {
    # Validate that $1 is a non-negative integer
    [[ "$1" =~ ^[0-9]+$ ]] || die "'$1' is not a valid number"
}

require_seconds() {
    [[ "$1" =~ ^[0-9]+([.][0-9]+)?$ ]] || die "'$1' is not a valid seconds value"
}

require_hours() {
    [[ "$1" =~ ^[0-9]+$ ]] || die "'$1' is not a valid hour count"
}

check_deps() {
    command -v zmx >/dev/null 2>&1 || die "zmx not found. Install zmx first."
    command -v tmux >/dev/null 2>&1 || die "tmux not found. Install with your package manager."
}

session_exists() {
    zmx list 2>/dev/null | grep -q "^session_name=$1	"
}

_session_names() {
    zmx list 2>/dev/null | sed -n 's/^session_name=\([^\t]*\).*/\1/p'
}

session_clients() {
    local target="$1"
    local line session clients
    while IFS= read -r line; do
        session="$(echo "$line" | sed -n 's/^session_name=\([^\t]*\).*/\1/p')"
        [[ "$session" == "$target" ]] || continue
        clients="$(echo "$line" | sed -n 's/.*clients=\([0-9]*\).*/\1/p')"
        echo "${clients:-0}"
        return 0
    done < <(zmx list 2>/dev/null)
    return 1
}

bridge_exists() {
    tmux has-session -t "$(bridge_name "$1")" 2>/dev/null
}

_search() {
    # Use rg if available, fall back to grep -E
    if command -v rg >/dev/null 2>&1; then
        rg "$@"
    else
        grep -E "$@"
    fi
}

normalize_type_text() {
    printf '%s' "$1" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//'
}

guard_send_keys() {
    local key
    for key in "$@"; do
        case "$key" in
            C-c|C-d|C-z)
                echo "dangerous control key '$key' is reserved for direct human control"
                return 1
                ;;
        esac
    done
}

json_escape() {
    printf '%s' "$1" | sed ':a;N;$!ba;s/\\/\\\\/g;s/"/\\"/g;s/\t/\\t/g;s/\r/\\r/g;s/\n/\\n/g'
}

current_repo_name() {
    local git_root=""
    if command -v git >/dev/null 2>&1 &&
       git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
        basename "$git_root"
    else
        basename "$PWD"
    fi
}

json_or_null() {
    if [[ -n "$1" ]]; then
        printf '"%s"' "$(json_escape "$1")"
    else
        printf 'null'
    fi
}

audit_event() {
    local action="$1" session="$2" decision="$3" detail="$4" reason="${5:-}"
    local ts detail_json reason_json
    local target_alias actor_session actor_alias repo_name work_id intent_reason
    ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    detail_json="$(json_escape "$detail")"
    reason_json="$(json_escape "$reason")"
    target_alias="$(session_alias "$session")"
    actor_session="${ZMX_SESSION:-}"
    actor_alias=""
    if [[ -n "$actor_session" ]] && session_exists "$actor_session"; then
        actor_alias="$(session_alias "$actor_session")"
    fi
    repo_name="$(current_repo_name)"
    work_id="${SURROGATE_WORK_ID:-}"
    intent_reason="${SURROGATE_REASON:-}"
    printf '{"ts":"%s","action":"%s","session":"%s","target_alias":"%s","decision":"%s","detail":"%s","reason":"%s","actor_session":"%s","actor_alias":"%s","work_id":"%s","intent_reason":"%s","repo":"%s"}\n' \
        "$ts" "$action" "$session" "$(json_escape "$target_alias")" "$decision" "$detail_json" "$reason_json" \
        "$(json_escape "$actor_session")" "$(json_escape "$actor_alias")" "$(json_escape "$work_id")" \
        "$(json_escape "$intent_reason")" "$(json_escape "$repo_name")" >> "$AUDIT_FILE"
}

scan_with_dcg() {
    local text="$1"
    command -v dcg >/dev/null 2>&1 || return 0

    local dcg_output="" dcg_rc=0 reason=""
    set +e
    dcg_output="$(dcg --robot test "$text" 2>/dev/null)"
    dcg_rc=$?
    set -e

    case "$dcg_rc" in
        0) return 0 ;;
        1)
            reason="$(printf '%s\n' "$dcg_output" | sed -n 's/.*"reason":"\([^"]*\)".*/\1/p')"
            [[ -n "$reason" ]] || reason="blocked by dcg"
            echo "dcg denied payload: $reason"
            return 1
            ;;
        *)
            # DCG is an optional layer; surrogate's built-in guardrails remain authoritative.
            return 0
            ;;
    esac
}

# --- alias wordlists (100 adjectives × 100 nouns = 10,000 combinations) ---

ADJECTIVES=(
    astral binary bouncy brave bright buzzy calm chrome clever cosmic
    cozy cubic cyber dandy deft dizzy dreamy dusty eager elfin
    fancy fizzy fleet fluffy foggy funky fuzzy gentle giddy glossy
    golden groovy happy hasty hex hollow holo idle ionic jazzy
    jolly keen kinetic lanky laser lazy light lunar lucky lumpy
    magic mellow merry micro misty nifty nimble noble nova odd
    perky pixel plucky polar prismy proxy pudgy quaint quick quirky
    radiant rapid retro robo rosy rusty sassy shiny silly sleek
    snappy snowy sonic sparkly speedy spicy spry starry sunny swift
    tidal tiny turbo twin vivid wacky warm whimsy wild zappy
)

NOUNS=(
    badger beagle beacon bison bolt bunny capybara cheetah chipmunk clank
    comet corgi coyote crane cricket cube cyborg dingo dolphin drone
    falcon ferret finch fox gadget gecko gizmo goose griffin hamster
    hawk heron husky iguana jackal kelpie koala lemur llama lynx
    mantis marmot meerkat moose moth narwhal newt osprey otter owl
    panda parrot pelican penguin photon pixel puffin quail quokka rabbit
    raven reindeer robin rover sabot seal sensor shrew signal sloth
    sparrow sphinx sprocket squid stork swift tapir thrush toucan urchin
    vector viper walrus weasel widget wombat wren yak zebra zippy
    axolotl bobcat camel chameleon condor ermine flamingo hedgehog ibis jellyfish
)

# --- alias functions ---

# Cache: built once per invocation, maps session→alias and alias→session
declare -A _ALIAS_CACHE _ALIAS_REVERSE
_ALIAS_CACHE_BUILT=""

_load_custom_aliases() {
    # Load custom aliases from file: session=alias (one per line)
    local -n _out="$1"
    [[ -f "$ALIAS_FILE" ]] || return 0
    local _sess _cust
    while IFS='=' read -r _sess _cust; do
        [[ -z "$_sess" || "$_sess" == \#* ]] && continue
        _out["$_sess"]="$_cust"
    done < "$ALIAS_FILE"
}

_build_alias_cache() {
    [[ -n "$_ALIAS_CACHE_BUILT" ]] && return
    _ALIAS_CACHE=()
    _ALIAS_REVERSE=()

    # Load custom aliases first
    local -A custom_aliases
    _load_custom_aliases custom_aliases

    local -a sorted_names
    while IFS= read -r name; do
        sorted_names+=("$name")
    done < <(_session_names | sort)

    # Compute aliases: custom overrides hash-derived
    local -A base_count
    local h i c s base cnt
    for name in "${sorted_names[@]}"; do
        if [[ -n "${custom_aliases[$name]:-}" ]]; then
            # Custom alias — use directly
            _ALIAS_CACHE["$name"]="${custom_aliases[$name]}"
            _ALIAS_REVERSE["${custom_aliases[$name]}"]="$name"
        else
            # Hash-derived alias
            s="$name" h=5381
            for (( i=0; i<${#s}; i++ )); do
                printf -v c '%d' "'${s:$i:1}"
                h=$(( ((h << 5) + h + c) & 0x7FFFFFFF ))
            done
            base="${ADJECTIVES[$((h % 100))]}-${NOUNS[$((h / 100 % 100))]}"
            cnt="${base_count[$base]:-0}"
            cnt=$((cnt + 1))
            base_count["$base"]=$cnt
            if [[ $cnt -eq 1 ]]; then
                _ALIAS_CACHE["$name"]="$base"
                _ALIAS_REVERSE["$base"]="$name"
            else
                _ALIAS_CACHE["$name"]="${base}-${cnt}"
                _ALIAS_REVERSE["${base}-${cnt}"]="$name"
            fi
        fi
    done
    _ALIAS_CACHE_BUILT=1
}

session_alias() {
    _build_alias_cache
    if [[ -n "${_ALIAS_CACHE[$1]:-}" ]]; then
        echo "${_ALIAS_CACHE[$1]}"
        return 0
    fi

    local name="$1" h=5381 i c base
    for (( i=0; i<${#name}; i++ )); do
        printf -v c '%d' "'${name:$i:1}"
        h=$(( ((h << 5) + h + c) & 0x7FFFFFFF ))
    done
    base="${ADJECTIVES[$((h % 100))]}-${NOUNS[$((h / 100 % 100))]}"
    echo "$base"
}

resolve_session() {
    local input="$1"

    # 1. Exact match — always wins
    if session_exists "$input"; then
        echo "$input"
        return 0
    fi

    # 2. Alias lookup from reverse cache
    _build_alias_cache
    if [[ -n "${_ALIAS_REVERSE[$input]:-}" ]]; then
        echo "${_ALIAS_REVERSE[$input]}"
        return 0
    fi

    die "session '$input' not found (not a name or alias)"
}

current_live_session() {
    local session="${ZMX_SESSION:-}"
    [[ -n "$session" ]] || return 1
    session_exists "$session" || return 1
    echo "$session"
}

guard_self_target() {
    local target_session="$1"
    local current_session=""
    current_session="$(current_live_session 2>/dev/null || true)"
    [[ -n "$current_session" ]] || return 0
    [[ "$current_session" != "$target_session" ]] || {
        _build_alias_cache
        local current_alias="${_ALIAS_CACHE[$current_session]:-$(session_alias "$current_session")}"
        echo "refusing to message your own live session. You are $current_alias ($current_session). Use direct input in this session instead."
        return 1
    }
}

guard_self_cull() {
    local target_session="$1"
    local current_session=""
    current_session="$(current_live_session 2>/dev/null || true)"
    [[ -n "$current_session" ]] || return 0
    [[ "$current_session" != "$target_session" ]] || {
        _build_alias_cache
        local current_alias="${_ALIAS_CACHE[$current_session]:-$(session_alias "$current_session")}"
        echo "refusing to cull your own live session. You are $current_alias ($current_session). Detach or close it first."
        return 1
    }
}

zmx_socket_dir() {
    echo "/run/user/$(id -u)/zmx"
}

session_age_secs() {
    local session="$1"
    local socket_dir socket_path now mtime
    socket_dir="$(zmx_socket_dir)"
    socket_path="$socket_dir/$session"
    [[ -e "$socket_path" ]] || {
        echo 0
        return 0
    }
    now="$(date +%s)"
    mtime="$(stat -c %Y "$socket_path" 2>/dev/null || echo "$now")"
    if [[ "$mtime" -gt "$now" ]]; then
        echo 0
    else
        echo $(( now - mtime ))
    fi
}

format_age_secs() {
    local age="$1"
    if [[ "$age" -lt 60 ]]; then
        echo "${age}s"
    elif [[ "$age" -lt 3600 ]]; then
        echo "$((age / 60))m"
    elif [[ "$age" -lt 86400 ]]; then
        echo "$((age / 3600))h"
    else
        echo "$((age / 86400))d"
    fi
}

session_snippet() {
    local session="$1"
    local lines="${2:-5}"
    zmx history "$session" 2>/dev/null | tail -n "$lines" | sed '/^[[:space:]]*$/d' | tail -1 | tr '\t' ' ' | cut -c1-60
}

remove_custom_alias() {
    local session="$1"
    [[ -f "$ALIAS_FILE" ]] || return 0
    local tmp
    tmp="$(mktemp)"
    awk -F= -v target="$session" '$1 != target { print $0 }' "$ALIAS_FILE" > "$tmp"
    mv "$tmp" "$ALIAS_FILE"
    _ALIAS_CACHE_BUILT=""
}

remove_session_plumbing() {
    local session="$1"
    tmux kill-session -t "$(bridge_name "$session")" 2>/dev/null || true
    rm -f "$(lock_file "$session")" "$(watermark_file "$session")"
    remove_custom_alias "$session"
}

stale_candidates() {
    local older_than_hours="$1"
    local filter="${2:-}"
    local limit="${3:-0}"
    local cutoff_secs=$((older_than_hours * 3600))
    local current_session=""
    local line session clients age alias snippet
    local rows=""

    current_session="$(current_live_session 2>/dev/null || true)"
    _build_alias_cache

    rows="$(
        while IFS= read -r line; do
            session="$(echo "$line" | sed -n 's/^session_name=\([^\t]*\).*/\1/p')"
            clients="$(echo "$line" | sed -n 's/.*clients=\([0-9]*\).*/\1/p')"
            [[ -n "$session" ]] || continue
            if bridge_exists "$session" && [[ "${clients:-0}" -gt 0 ]]; then
                clients=$((clients - 1))
            fi
            [[ "${clients:-0}" -eq 0 ]] || continue
            [[ "$session" != "$current_session" ]] || continue
            age="$(session_age_secs "$session")"
            [[ "$age" -ge "$cutoff_secs" ]] || continue
            alias="${_ALIAS_CACHE[$session]:-$(session_alias "$session")}"
            snippet="$(session_snippet "$session" 5)"
            if [[ -n "$filter" ]]; then
                if ! printf '%s\n' "$alias $session $snippet" | _search -qi -- "$filter" 2>/dev/null; then
                    continue
                fi
            fi
            printf '%s\t%s\t%s\t%s\n' "$age" "$alias" "$session" "$snippet"
        done < <(zmx list 2>/dev/null) | sort -rn -k1,1
    )"

    [[ -n "$rows" ]] || return 0
    if [[ "$limit" -gt 0 ]]; then
        printf '%s\n' "$rows" | head -n "$limit"
    else
        printf '%s\n' "$rows"
    fi
}

ensure_cullable_session() {
    local session="$1"
    local guard_reason=""
    local clients=""
    if ! guard_reason="$(guard_self_cull "$session")"; then
        echo "$guard_reason"
        return 1
    fi
    clients="$(session_effective_clients "$session")"
    if [[ "${clients:-0}" -gt 0 ]]; then
        echo "session '$session' has ${clients} client(s); detach it before culling"
        return 1
    fi
}

cull_session() {
    local session="$1"
    zmx kill "$session" >/dev/null 2>&1 || die "failed to cull session '$session'"
    remove_session_plumbing "$session"
}

# --- remaining helpers ---

usage() {
    cat <<'EOF'
surrogate - deterministic terminal control for zmx sessions

Usage: surrogate <command> [args]

High-value flows:
  surrogate help list                 Show discoverability-oriented list usage
  surrogate who --recent 20           Find the most recent interesting sessions
  surrogate list --cwd                Show repo + cwd hints for every session
  surrogate type --message <session> "long prose"
                                      Safest way to send agent prose
  surrogate submit <session>          Recover a visibly staged prompt
  surrogate read <session> -n 40      Inspect what happened after a send/type

Commands:
  list  [-n LINES] [--cwd] [--json]
                                List sessions by alias; add --cwd/--json for repo and UI context
  stale [--older-than HOURS]    List oldest detached stale zmx sessions (default: 24h)
  send  <session> [keys...]     Send tmux send-keys style keystrokes
  submit <session>              Press Enter for a staged prompt
  type  [--message] <session> <text>
                                Type literal text followed by Enter
  read  <session> [-n LINES]    Read recent output (default: 20 lines)
  wait  <session> <pattern> [-t TIMEOUT]
                                Wait for regex pattern in new output (default: 30s)
  find  <query> [-n LINES]      Search all sessions for text (grep, default: last 200 lines)
  who   [-n LINES] [--recent N|2h] [--project NAME] [--cwd PATH] [--json]
                                Show sessions with age and last visible line
  active [--all]                Show attached sessions (--all includes non-empty detached)
  peek  [-n LINES] [--filter PATTERN]
                                Batch read last N lines from all sessions (default: 5)
  alias <session>               Show the alias for a session
  whoami                        Show current session name and alias
  rename <session> <new-alias>  Set a custom alias (session ID stays the same)
  cull  <session>...            Cull detached zmx sessions by name or alias
  cull  --stale [options]       Cull oldest detached stale zmx sessions in batch
  bridge <session>              Pre-create tmux bridge for a zmx session
  cleanup [--all|--dead]        Remove stale or all bridge sessions
  status                        Show bridge health

Session arguments accept either the full zmx name or the auto-generated alias.
Each session gets a deterministic adjective-noun alias (e.g. lazy-sheep).

Environment:
  SURROGATE_LABEL=on       Prepend [SURROGATE <alias>] to typed text (default)
  SURROGATE_LABEL=off      No prefix
  SURROGATE_LABEL=verbose  Include process name, cwd, PID in prefix
  SURROGATE_AUDIT_FILE     Audit log path (default: /tmp/surrogate-audit.jsonl)
  SURROGATE_TYPE_ENTER_DELAY_SECS
                          Fixed pause before Enter in `type` (default: 0.02)
  SURROGATE_TYPE_POSTCHECK_SECS
                          Fixed pause before shell failure warning check (default: 0.15)

Special keys (for send):
  Enter Escape Tab Space BSpace
  C-u C-l (Ctrl combos)
  Up Down Left Right

Examples:
  surrogate list
  surrogate help list
  surrogate list --cwd
  surrogate stale --older-than 72 --limit 20
  surrogate cull sleepy-otter
  surrogate cull --stale --older-than 48 --filter '2026-03-08' --limit 10
  surrogate who --recent 2h --project surrogate
  surrogate who --cwd /home/raw/Documents/GitHub/surrogate --json
  surrogate type --message lively-otter "Please review the patch plan above."
  surrogate submit lazy-sheep
  surrogate type lazy-sheep "echo hello"
  surrogate type 2026-03-08_15-07-15_EDT-132628 "echo hello"
  surrogate send my-session Escape ":wq" Enter
  surrogate read bold-crane -n 50
  surrogate alias 2026-03-08_15-07-15_EDT-132628

EOF
    exit 0
}

list_usage() {
    cat <<'EOF'
usage: surrogate list [-n LINES] [--cwd] [--json]

List every zmx session with deterministic aliasing. Use `--cwd` or `--json`
when you need visible repo/cwd/ui hints.

Options:
  -n LINES   Inspect this many recent history lines for repo/cwd/ui hints (default: 10)
  --cwd      Include full cwd hint column in text output
  --json     Emit machine-readable session metadata

Notes:
  - `project` and `cwd_hint` come from recent visible output, not process introspection.
  - `ui_hint` is a deterministic hint: `shell`, `agent`, or `unknown`.
EOF
}

who_usage() {
    cat <<'EOF'
usage: surrogate who [-n LINES] [--recent N|2h] [--project NAME] [--cwd PATH] [--json]

Show the newest sessions first. By default, `who` shows the 20 most recent sessions.
Use `--recent N` or `--recent 2h` to widen or narrow the window.
EOF
}

type_usage() {
    cat <<'EOF'
usage: surrogate type [--message] <session> <text>

Modes:
  default     Literal text + Enter. Shell-safe by default: if target looks like a shell,
              Surrogate suppresses the prose prefix and warns if the shell immediately
              reports command-not-found or syntax errors.
  --message   Agent-message mode. Normalizes long prose and requires an agent-like target.
              Refuses shell and unknown targets to avoid accidental command execution.

Recovery:
  If text is visibly staged and only Enter is missing, run:
    surrogate submit <session>
EOF
}

send_usage() {
    cat <<'EOF'
usage: surrogate send <session> <keys...>

Send tmux-style keys directly. Use this for Enter, Escape, arrows, or manual repair.
Dangerous control keys C-c, C-d, and C-z are intentionally blocked.
EOF
}

submit_usage() {
    cat <<'EOF'
usage: surrogate submit <session>

Press Enter for a visibly staged prompt. This is the one obvious repair path when
text has landed in the target input but was not submitted.
EOF
}

cmd_help() {
    case "${1:-}" in
        ""|-h|--help) usage ;;
        list) list_usage ;;
        who) who_usage ;;
        type) type_usage ;;
        send) send_usage ;;
        submit) submit_usage ;;
        stale) echo "usage: surrogate stale [--older-than HOURS] [--filter PATTERN] [--limit N]" ;;
        cull) echo "usage: surrogate cull <session>... | surrogate cull --stale [--older-than HOURS] [--filter PATTERN] [--limit N] [--dry-run]" ;;
        *) die "unknown help topic: $1" ;;
    esac
}

bridge_name() {
    echo "${BRIDGE_PREFIX}${1}"
}

lock_file() {
    echo "${SURROGATE_TMP}/surrogate-${1}.lock"
}

watermark_file() {
    echo "${SURROGATE_TMP}/surrogate-${1}.watermark"
}

line_count() {
    zmx history "$1" 2>/dev/null | wc -l
}

session_age_seconds() {
    local session="$1"
    local zmx_dir="/run/user/$(id -u)/zmx"
    if [[ -e "$zmx_dir/$session" ]]; then
        local now mtime
        now="$(date +%s)"
        mtime="$(stat -c %Y "$zmx_dir/$session" 2>/dev/null || echo 0)"
        echo $(( now - mtime ))
    else
        echo 2147483647
    fi
}

format_age() {
    local age="$1"
    if [[ "$age" -lt 60 ]]; then printf '%ss' "$age"
    elif [[ "$age" -lt 3600 ]]; then printf '%sm' $(( age / 60 ))
    elif [[ "$age" -lt 86400 ]]; then printf '%sh' $(( age / 3600 ))
    else printf '%sd' $(( age / 86400 )); fi
}

session_recent_history() {
    local session="$1" lines="$2"
    if [[ "$lines" -eq 0 ]]; then
        return 0
    fi
    zmx history "$session" 2>/dev/null | tail -n "$lines"
}

session_base_records() {
    _build_alias_cache

    local line session clients age_seconds ago attached
    while IFS= read -r line; do
        session="$(echo "$line" | sed -n 's/^session_name=\([^\t]*\).*/\1/p')"
        clients="$(echo "$line" | sed -n 's/.*clients=\([0-9]*\).*/\1/p')"
        [[ -n "$session" ]] || continue
        [[ -n "$clients" ]] || clients=0

        age_seconds="$(session_age_seconds "$session")"
        ago="$(format_age "$age_seconds")"
        attached=""
        [[ "$clients" -gt 0 ]] && attached="*"

        printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
            "$age_seconds" "$ago" "$attached" "$clients" "${_ALIAS_CACHE[$session]}" "$session"
    done < <(zmx list 2>/dev/null)
}

session_visible_context() {
    local session="$1" lines="${2:-10}"
    local history snippet cwd_hint project_hint ui_hint

    history="$(session_recent_history "$session" "$lines")"
    snippet="$(visible_snippet "$history")"
    cwd_hint="$(visible_path_hint "$history")"
    project_hint="$(project_from_path "$cwd_hint")"
    ui_hint="$(ui_hint_from_history "$history")"

    printf '%s\t%s\t%s\t%s\n' "$snippet" "$cwd_hint" "$project_hint" "$ui_hint"
}

visible_snippet() {
    local text="$1"
    printf '%s' "$text" | sed '/^[[:space:]]*$/d' | tail -1 | tr '\t\r\n' '   ' | cut -c1-60
}

last_visible_line() {
    printf '%s\n' "$1" | sed '/^[[:space:]]*$/d' | tail -1
}

visible_path_hint() {
    local text="$1"
    printf '%s\n' "$text" |
        grep -oE '((~|/)[^[:space:]]*/[^[:space:]]+)' 2>/dev/null |
        sed 's#[,;:.)\]}]+$##' |
        tail -1
}

project_from_path() {
    [[ -n "${1:-}" ]] || return 0
    basename "${1%/}"
}

ui_hint_from_history() {
    local text="$1"
    local last_line=""
    last_line="$(last_visible_line "$text")"

    if printf '%s\n' "$text" | grep -Eqi '^[[:space:]]*[›•✻]' ||
       printf '%s\n' "$text" | grep -Eqi 'Use /skills to list available skills|Model interrupted|[0-9]+% left|tokens left|background terminal running|Worked for [0-9]+m'; then
        echo "agent"
        return 0
    fi

    if [[ -n "$last_line" ]] &&
       printf '%s\n' "$last_line" | grep -Eq '([#$%>] ?|❯ ?)$'; then
        echo "shell"
        return 0
    fi

    echo "unknown"
}

shell_error_reason() {
    local text="$1"
    local match=""
    match="$(
        printf '%s\n' "$text" |
            grep -Ei -m1 'command not found|syntax error|unexpected EOF|unexpected token|No such file or directory|parse error|not a valid identifier' ||
            true
    )"
    [[ -n "$match" ]] || return 1
    printf '%s' "$match" | tr '\t\r\n' '   ' | cut -c1-120
}

session_records() {
    local lines="${1:-10}"
    local base_rows="${2:-}"
    local age_seconds ago attached clients alias session snippet cwd_hint project_hint ui_hint

    if [[ -z "$base_rows" ]]; then
        base_rows="$(session_base_records)"
    fi

    while IFS=$'\t' read -r age_seconds ago attached clients alias session; do
        [[ -n "$session" ]] || continue
        IFS=$'\t' read -r snippet cwd_hint project_hint ui_hint < <(session_visible_context "$session" "$lines")
        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
            "$age_seconds" "$ago" "$attached" "$clients" "$alias" \
            "$session" "$snippet" "$cwd_hint" "$project_hint" "$ui_hint"
    done <<< "$base_rows"
}

parse_recent_filter() {
    local raw="$1"
    if [[ "$raw" =~ ^[0-9]+$ ]]; then
        printf 'count:%s\n' "$raw"
        return 0
    fi

    if [[ "$raw" =~ ^([0-9]+)([smhd])$ ]]; then
        local value="${BASH_REMATCH[1]}"
        local unit="${BASH_REMATCH[2]}"
        local seconds="$value"
        case "$unit" in
            s) ;;
            m) seconds=$(( value * 60 )) ;;
            h) seconds=$(( value * 3600 )) ;;
            d) seconds=$(( value * 86400 )) ;;
        esac
        printf 'age:%s\n' "$seconds"
        return 0
    fi

    die "'$raw' is not a valid recent filter (use N or Ns/Nm/Nh/Nd)"
}

update_watermark() {
    local session="$1"
    line_count "$session" > "$(watermark_file "$session")"
}

ensure_bridge() {
    local session="$1"
    local bridge
    bridge="$(bridge_name "$session")"

    session_exists "$session" || die "session '$session' not found"

    # Check if bridge tmux session exists and is healthy
    if tmux has-session -t "$bridge" 2>/dev/null; then
        # Verify the pane is still running zmx
        local cmd
        cmd="$(tmux display-message -t "$bridge" -p '#{pane_current_command}' 2>/dev/null || true)"
        if [[ -n "$cmd" ]]; then
            return 0
        fi
        # Stale bridge — kill and recreate
        tmux kill-session -t "$bridge" 2>/dev/null || true
    fi

    # Create bridge
    tmux new-session -d -s "$bridge" "zmx attach $session"
    sleep 1
}

session_effective_clients() {
    local session="$1"
    local clients
    clients="$(session_clients "$session" 2>/dev/null || echo 0)"
    if bridge_exists "$session" && [[ "${clients:-0}" -gt 0 ]]; then
        clients=$((clients - 1))
    fi
    echo "${clients:-0}"
}

# --- subcommands ---

cmd_list() {
    check_deps
    _build_alias_cache
    local lines=10
    local show_cwd=0
    local json=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) list_usage; return 0 ;;
            -n) [[ $# -ge 2 ]] || die "-n requires a number"; require_int "$2"; lines="$2"; shift 2 ;;
            --cwd) show_cwd=1; shift ;;
            --json) json=1; shift ;;
            *) die "unknown flag: $1" ;;
        esac
    done

    if [[ "$show_cwd" -eq 0 && "$json" -eq 0 ]]; then
        # Fast path: plain list stays cheap and delegates directly to zmx session names.
        while IFS= read -r session; do
            printf "%-20s %s\n" "${_ALIAS_CACHE[$session]}" "$session"
        done < <(_session_names)
        return 0
    fi

    local rows total=0
    rows="$(session_records "$lines" | sort -t $'\t' -k5,5 -k6,6)"
    [[ -n "$rows" ]] && total="$(printf '%s\n' "$rows" | sed '/^$/d' | wc -l)"

    if [[ "$json" -eq 1 ]]; then
        printf '{"count":%s,"sessions":[' "$total"
        local first=1
        while IFS=$'\t' read -r age_seconds ago attached clients alias session snippet cwd_hint project_hint ui_hint; do
            [[ -n "$session" ]] || continue
            [[ "$first" -eq 1 ]] || printf ','
            first=0
            printf '{"alias":"%s","session":"%s","project_hint":%s,"cwd_hint":%s,"ui_hint":"%s","clients":%s,"attached":%s}' \
                "$(json_escape "$alias")" \
                "$(json_escape "$session")" \
                "$(json_or_null "$project_hint")" \
                "$(json_or_null "$cwd_hint")" \
                "$(json_escape "$ui_hint")" \
                "$clients" \
                "$([[ -n "$attached" ]] && printf 'true' || printf 'false')"
        done <<< "$rows"
        echo ']}'
        return 0
    fi

    if [[ "$show_cwd" -eq 1 ]]; then
        printf "%-18s %-42s %-14s %-8s %s\n" "ALIAS" "SESSION" "PROJECT" "UI" "CWD"
        while IFS=$'\t' read -r _age_seconds _ago _attached _clients alias session _snippet cwd_hint project_hint ui_hint; do
            [[ -n "$session" ]] || continue
            printf "%-18s %-42s %-14s %-8s %s\n" "$alias" "$session" "${project_hint:--}" "$ui_hint" "${cwd_hint:--}"
        done <<< "$rows"
    else
        printf "%-18s %-42s %-14s %s\n" "ALIAS" "SESSION" "PROJECT" "UI"
        while IFS=$'\t' read -r _age_seconds _ago _attached _clients alias session _snippet _cwd_hint project_hint ui_hint; do
            [[ -n "$session" ]] || continue
            printf "%-18s %-42s %-14s %s\n" "$alias" "$session" "${project_hint:--}" "$ui_hint"
        done <<< "$rows"
    fi
}

cmd_stale() {
    check_deps
    local older_than_hours=24
    local filter=""
    local limit=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --older-than) [[ $# -ge 2 ]] || die "--older-than requires an hour count"; require_hours "$2"; older_than_hours="$2"; shift 2 ;;
            --filter) [[ $# -ge 2 ]] || die "--filter requires a pattern"; filter="$2"; shift 2 ;;
            --limit) [[ $# -ge 2 ]] || die "--limit requires a count"; require_int "$2"; limit="$2"; shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done

    local rows=""
    rows="$(stale_candidates "$older_than_hours" "$filter" "$limit")"
    if [[ -z "$rows" ]]; then
        echo "no stale sessions older than ${older_than_hours}h"
        return 0
    fi

    printf "%-4s %-18s %-42s %s\n" "AGE" "ALIAS" "SESSION" "SNIPPET"
    while IFS=$'\t' read -r age alias session snippet; do
        [[ -n "$session" ]] || continue
        printf "%-4s %-18s %-42s %s\n" "$(format_age_secs "$age")" "$alias" "$session" "$snippet"
    done <<< "$rows"
    echo "--- $(printf '%s\n' "$rows" | sed '/^$/d' | wc -l) stale session(s) older than ${older_than_hours}h ---"
}

cmd_send() {
    check_deps
    case "${1:-}" in
        -h|--help) send_usage; return 0 ;;
    esac
    [[ $# -ge 1 ]] || die "usage: surrogate send <session> [keys...]"
    local session
    session="$(resolve_session "$1")"
    shift
    local send_detail="$*"
    local guard_reason=""
    if ! guard_reason="$(guard_self_target "$session")"; then
        audit_event "send" "$session" "deny" "$send_detail" "$guard_reason"
        die "$guard_reason"
    fi
    if ! guard_reason="$(guard_send_keys "$@")"; then
        audit_event "send" "$session" "deny" "$send_detail" "$guard_reason"
        die "$guard_reason"
    fi

    ensure_bridge "$session"
    update_watermark "$session"

    local bridge
    bridge="$(bridge_name "$session")"
    local lock
    lock="$(lock_file "$session")"

    (
        flock 9
        tmux send-keys -t "$bridge" "$@"
    ) 9>"$lock"
    audit_event "send" "$session" "allow" "$send_detail"
}

cmd_submit() {
    case "${1:-}" in
        -h|--help) submit_usage; return 0 ;;
    esac
    [[ $# -eq 1 ]] || die "usage: surrogate submit <session>"
    cmd_send "$1" Enter
}

_surrogate_prefix() {
    # Build the [SURROGATE ...] prefix based on SURROGATE_LABEL mode
    case "$SURROGATE_LABEL" in
        off) return ;;
        verbose)
            local sender_info=""
            if [[ -n "${ZMX_SESSION:-}" ]]; then
                _build_alias_cache
                local sender_alias="${_ALIAS_CACHE[$ZMX_SESSION]:-$ZMX_SESSION}"
                sender_info=" ${sender_alias}"
            fi
            local proc_name=""
            proc_name="$(ps -o comm= -p $PPID 2>/dev/null || true)"
            local cwd_short=""
            cwd_short="$(basename "$PWD")"
            printf '[SURROGATE%s %s %s PID:%s] ' "$sender_info" "${proc_name:-?}" "$cwd_short" "$$"
            ;;
        *)  # "on" (default)
            if [[ -n "${ZMX_SESSION:-}" ]]; then
                _build_alias_cache
                local sender_alias="${_ALIAS_CACHE[$ZMX_SESSION]:-$ZMX_SESSION}"
                printf '[SURROGATE %s] ' "$sender_alias"
            else
                printf '[SURROGATE] '
            fi
            ;;
    esac
}

cmd_type() {
    check_deps
    local message_mode=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) type_usage; return 0 ;;
            --message) message_mode=1; shift ;;
            *) break ;;
        esac
    done

    [[ $# -ge 2 ]] || die "usage: surrogate type [--message] <session> <text>"
    local requested_session="$1"
    local session
    session="$(resolve_session "$requested_session")"
    local original_text="$2"
    local text
    text="$(normalize_type_text "$original_text")"
    [[ -n "$text" ]] || die "type text must not be empty"
    require_seconds "$SURROGATE_TYPE_ENTER_DELAY_SECS"
    require_seconds "$SURROGATE_TYPE_POSTCHECK_SECS"

    local history ui_hint
    history="$(session_recent_history "$session" 10)"
    ui_hint="$(ui_hint_from_history "$history")"

    local guard_reason=""
    if ! guard_reason="$(guard_self_target "$session")"; then
        audit_event "type" "$session" "deny" "$original_text" "$guard_reason"
        die "$guard_reason"
    fi
    if [[ "$message_mode" -eq 1 && "$ui_hint" != "agent" ]]; then
        guard_reason="--message requires an agent-like target; current ui_hint is '$ui_hint'"
        audit_event "type" "$session" "deny" "$original_text" "$guard_reason"
        die "$guard_reason"
    fi
    if [[ "$message_mode" -eq 0 ]] && ! guard_reason="$(scan_with_dcg "$text")"; then
        audit_event "type" "$session" "deny" "$original_text" "$guard_reason"
        die "$guard_reason"
    fi

    local start_lines=0
    start_lines="$(line_count "$session")"

    # Prepend surrogate label for agent-like contexts and explicit message sends.
    local prefix
    prefix=""
    if [[ "$message_mode" -eq 1 || "$ui_hint" != "shell" ]]; then
        prefix="$(_surrogate_prefix)"
    fi
    if [[ -n "$prefix" ]]; then
        text="${prefix}${text}"
    fi

    ensure_bridge "$session"
    update_watermark "$session"

    local bridge
    bridge="$(bridge_name "$session")"
    local lock
    lock="$(lock_file "$session")"

    if ! (
        flock 9
        tmux send-keys -t "$bridge" -l "$text"
        sleep "$SURROGATE_TYPE_ENTER_DELAY_SECS"
        tmux send-keys -t "$bridge" Enter
    ) 9>"$lock"; then
        die "type delivery failed; if the text is already staged, run: surrogate submit $requested_session"
    fi
    audit_event "type" "$session" "allow" "$text"

    if [[ "$ui_hint" == "shell" ]]; then
        sleep "$SURROGATE_TYPE_POSTCHECK_SECS"
        local new_output shell_reason
        new_output="$(zmx history "$session" 2>/dev/null | tail -n +"$((start_lines + 1))")"
        shell_reason="$(shell_error_reason "$new_output" || true)"
        if [[ -n "$shell_reason" ]]; then
            warn "target shell immediately reported: $shell_reason"
            warn "inspect with: surrogate read $requested_session -n 40"
        fi
    fi
}

cmd_read() {
    check_deps
    [[ $# -ge 1 ]] || die "usage: surrogate read <session> [-n LINES]"
    local session
    session="$(resolve_session "$1")"
    shift

    local lines=20
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n) [[ $# -ge 2 ]] || die "-n requires a number"; require_int "$2"; lines="$2"; shift 2 ;;
            *)  die "unknown flag: $1" ;;
        esac
    done

    zmx history "$session" | tail -n "$lines"
}

cmd_wait() {
    check_deps
    [[ $# -ge 2 ]] || die "usage: surrogate wait <session> <pattern> [-t TIMEOUT]"
    local session
    session="$(resolve_session "$1")"
    local pattern="$2"
    shift 2

    local timeout=30
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -t) [[ $# -ge 2 ]] || die "-t requires seconds"; require_int "$2"; timeout="$2"; shift 2 ;;
            *)  die "unknown flag: $1" ;;
        esac
    done

    local wm_file
    wm_file="$(watermark_file "$session")"
    local watermark=0
    if [[ -f "$wm_file" ]]; then
        watermark="$(cat "$wm_file")"
    fi

    local elapsed=0
    while [[ $elapsed -lt $timeout ]]; do
        if zmx history "$session" | tail -n +"$((watermark + 1))" | grep -qE "$pattern"; then
            return 0
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done

    die "timeout after ${timeout}s waiting for pattern: $pattern"
}

cmd_find() {
    check_deps
    _build_alias_cache
    [[ $# -ge 1 ]] || die "usage: surrogate find <query> [-n LINES] [-C CONTEXT]"
    local query="$1"
    [[ -z "$query" ]] && die "query must not be empty"
    shift

    local lines=200
    local context=1
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n) [[ $# -ge 2 ]] || die "-n requires a number"; require_int "$2"; lines="$2"; shift 2 ;;
            -C) [[ $# -ge 2 ]] || die "-C requires a number"; require_int "$2"; context="$2"; shift 2 ;;
            *)  die "unknown flag: $1" ;;
        esac
    done

    local found=0
    while IFS= read -r session; do
        local output
        output="$(zmx history "$session" 2>/dev/null | tail -n "$lines" | _search -i -C "$context" -- "$query" 2>/dev/null || true)"
        if [[ -n "$output" ]]; then
            local count
            count="$(echo "$output" | _search -c -i -- "$query" 2>/dev/null || echo 0)"
            echo "═══ ${_ALIAS_CACHE[$session]}  $session ($count matches) ═══"
            echo "$output"
            echo ""
            found=$((found + 1))
        fi
    done < <(_session_names)

    if [[ $found -eq 0 ]]; then
        echo "no matches for '$query' across $(zmx list 2>/dev/null | wc -l) sessions"
    else
        echo "--- $found session(s) matched ---"
    fi
}

cmd_who() {
    check_deps

    local lines=10
    local json=0
    local recent_count=""
    local recent_age_max=""
    local recent_explicit=0
    local project_filter=""
    local cwd_filter=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) who_usage; return 0 ;;
            -n) [[ $# -ge 2 ]] || die "-n requires a number"; require_int "$2"; lines="$2"; shift 2 ;;
            --json) json=1; shift ;;
            --project) [[ $# -ge 2 ]] || die "--project requires a name"; project_filter="$2"; shift 2 ;;
            --cwd) [[ $# -ge 2 ]] || die "--cwd requires a path"; cwd_filter="$2"; shift 2 ;;
            --recent)
                [[ $# -ge 2 ]] || die "--recent requires a value"
                local recent_mode
                recent_mode="$(parse_recent_filter "$2")"
                recent_explicit=1
                case "$recent_mode" in
                    count:*) recent_count="${recent_mode#count:}" ;;
                    age:*)
                        recent_age_max="${recent_mode#age:}"
                        recent_count=""
                        ;;
                esac
                shift 2
                ;;
            *)  die "unknown flag: $1" ;;
        esac
    done

    if [[ "$recent_explicit" -eq 0 ]]; then
        recent_count=20
    fi

    local base_records selected_base records filtered=""
    base_records="$(session_base_records | sort -t $'\t' -k1,1n -k6,6)"
    if [[ -n "$recent_age_max" ]]; then
        base_records="$(
            while IFS=$'\t' read -r age_seconds ago attached clients alias session; do
                [[ -n "$session" ]] || continue
                [[ "$age_seconds" -le "$recent_age_max" ]] || continue
                printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
                    "$age_seconds" "$ago" "$attached" "$clients" "$alias" "$session"
            done <<< "$base_records"
        )"
    fi

    selected_base="$base_records"
    if [[ "$recent_explicit" -eq 0 && -z "$project_filter" && -z "$cwd_filter" ]]; then
        selected_base="$(printf '%s\n' "$selected_base" | sed '/^$/d' | head -n "$recent_count")"
    fi

    records="$(session_records "$lines" "$selected_base")"
    while IFS=$'\t' read -r age_seconds ago attached clients alias session snippet cwd_hint project_hint ui_hint; do
        [[ -n "$session" ]] || continue
        if [[ -n "$cwd_filter" && ( -z "$cwd_hint" || "$cwd_hint" != "$cwd_filter"* ) ]]; then
            continue
        fi

        if [[ -n "$project_filter" && "$project_hint" != "$project_filter" ]]; then
            continue
        fi

        filtered+=$(printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s' \
            "$age_seconds" "$ago" "$attached" "$clients" "$alias" \
            "$session" "$snippet" "$cwd_hint" "$project_hint" "$ui_hint")
        filtered+=$'\n'
    done <<< "$records"

    local sorted
    sorted="$(printf '%s' "$filtered" | sed '/^$/d')"
    if [[ "$recent_explicit" -eq 1 && -n "$recent_count" ]]; then
        sorted="$(printf '%s\n' "$sorted" | head -n "$recent_count")"
    fi

    local total=0
    [[ -n "$sorted" ]] && total="$(printf '%s\n' "$sorted" | sed '/^$/d' | wc -l)"

    if [[ "$json" -eq 1 ]]; then
        printf '{"count":%s,"recent_first":true,"sessions":[' "$total"
        local first=1
        while IFS=$'\t' read -r age_seconds ago attached clients alias session snippet cwd_hint project_hint ui_hint; do
            [[ -z "$session" ]] && continue
            [[ "$first" -eq 1 ]] || printf ','
            first=0
            printf '{"alias":"%s","session":"%s","clients":%s,"attached":%s,"age":"%s","age_seconds":%s,"snippet":"%s","cwd_hint":%s,"project_hint":%s,"ui_hint":"%s"}' \
                "$(json_escape "$alias")" \
                "$(json_escape "$session")" \
                "$clients" \
                "$([[ -n "$attached" ]] && printf 'true' || printf 'false')" \
                "$(json_escape "$ago")" \
                "$age_seconds" \
                "$(json_escape "$snippet")" \
                "$(json_or_null "$cwd_hint")" \
                "$(json_or_null "$project_hint")" \
                "$(json_escape "$ui_hint")"
        done <<< "$sorted"
        echo ']}'
        return 0
    fi

    while IFS=$'\t' read -r _age_seconds ago attached _clients alias session snippet _cwd_hint project_hint ui_hint; do
        [[ -z "$session" ]] && continue
        printf "%-4s %-8s %-18s %-42s %-12s %s\n" "${ago}${attached}" "$ui_hint" "$alias" "$session" "${project_hint:--}" "$snippet"
    done <<< "$sorted"

    if [[ "$recent_explicit" -eq 0 && -z "$project_filter" && -z "$cwd_filter" ]]; then
        echo "── $total sessions shown (* = attached, newest first; default window) ──"
    else
        echo "── $total sessions (* = attached, newest first) ──"
    fi
}

cmd_active() {
    check_deps
    _build_alias_cache

    local mode="attached"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all)  mode="all"; shift ;;
            *)      die "unknown flag: $1 (use --all to include detached)" ;;
        esac
    done

    printf "%-18s %-45s %-8s %s\n" "ALIAS" "SESSION" "CLIENTS" "SNIPPET"
    printf "%-18s %-45s %-8s %s\n" "-----" "-------" "-------" "-------"

    local found=0
    while IFS= read -r line; do
        local session clients
        session="$(echo "$line" | sed -n 's/^session_name=\([^\t]*\).*/\1/p')"
        clients="$(echo "$line" | sed -n 's/.*clients=\([0-9]*\).*/\1/p')"
        [[ -z "$session" ]] && continue

        # Default: only show attached sessions (clients > 0)
        if [[ "$mode" == "attached" && "$clients" -eq 0 ]]; then
            continue
        fi

        # For --all mode, check if session has any history (non-empty)
        if [[ "$mode" == "all" ]]; then
            local lc
            lc="$(zmx history "$session" 2>/dev/null | wc -l)"
            [[ "$lc" -eq 0 ]] && continue
        fi

        local snippet
        snippet="$(zmx history "$session" 2>/dev/null | tail -n 5 | sed '/^[[:space:]]*$/d' | tail -1 | cut -c1-60)"
        printf "%-18s %-45s %-8s %s\n" "${_ALIAS_CACHE[$session]}" "$session" "$clients" "$snippet"
        found=$((found + 1))
    done < <(zmx list 2>/dev/null)

    echo "--- $found active session(s) ---"
}

cmd_peek() {
    check_deps
    _build_alias_cache

    local lines=5
    local filter=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n) [[ $# -ge 2 ]] || die "-n requires a number"; require_int "$2"; lines="$2"; shift 2 ;;
            --filter) [[ $# -ge 2 ]] || die "--filter requires a pattern"; filter="$2"; shift 2 ;;
            *)  die "unknown flag: $1" ;;
        esac
    done

    local count=0
    while IFS= read -r session; do
        local output
        output="$(zmx history "$session" 2>/dev/null | tail -n "$lines" | sed '/^[[:space:]]*$/d')"
        [[ -z "$output" ]] && continue

        # Apply filter if given (matches against output content AND alias)
        if [[ -n "$filter" ]]; then
            if ! echo "$output" | _search -qi -- "$filter" 2>/dev/null; then
                if ! echo "${_ALIAS_CACHE[$session]} $session" | _search -qi -- "$filter" 2>/dev/null; then
                    continue
                fi
            fi
        fi

        echo "─── ${_ALIAS_CACHE[$session]}  $session ───"
        echo "$output"
        echo ""
        count=$((count + 1))
    done < <(_session_names)

    echo "--- peeked $count session(s) ---"
}

cmd_alias() {
    check_deps
    [[ $# -ge 1 ]] || die "usage: surrogate alias <session>"
    local session
    session="$(resolve_session "$1")"
    _build_alias_cache
    echo "${_ALIAS_CACHE[$session]}"
}

whoami_usage() {
    cat <<'EOF'
usage: surrogate whoami

Show the current zmx session name and its surrogate alias.
EOF
}

cmd_whoami() {
    check_deps
    case "${1:-}" in
        -h|--help)
            whoami_usage
            return 0
            ;;
    esac
    [[ $# -eq 0 ]] || die "usage: surrogate whoami"

    local session="${ZMX_SESSION:-}"
    if [[ -z "$session" ]]; then
        die "not inside a zmx session (ZMX_SESSION not set)"
    fi
    if ! session_exists "$session"; then
        die "current ZMX_SESSION '$session' is not present in zmx list (stale or leaked environment)"
    fi
    _build_alias_cache
    local alias="${_ALIAS_CACHE[$session]:-}"
    if [[ -z "$alias" ]]; then
        alias="$(session_alias "$session")"
    fi
    echo "$alias  $session"
}

cmd_rename() {
    check_deps
    [[ $# -ge 2 ]] || die "usage: surrogate rename <session> <new-alias>"
    local session
    session="$(resolve_session "$1")"
    local new_alias="$2"

    # Check the new alias doesn't collide with an existing session name
    if session_exists "$new_alias"; then
        die "'$new_alias' is a zmx session name, not an alias — use a different name"
    fi

    _build_alias_cache
    set +u
    local old_alias="${_ALIAS_CACHE[$session]:-$session}"
    set -u

    # Check the new alias isn't already taken by another session
    if [[ -n "${_ALIAS_REVERSE[$new_alias]:-}" ]]; then
        local other="${_ALIAS_REVERSE[$new_alias]}"
        if [[ "$other" != "$session" ]]; then
            die "alias '$new_alias' is already used by $other"
        fi
    fi

    # Write custom alias to file (append or update)
    if [[ -f "$ALIAS_FILE" ]] && grep -q "^${session}=" "$ALIAS_FILE" 2>/dev/null; then
        sed -i "s|^${session}=.*|${session}=${new_alias}|" "$ALIAS_FILE"
    else
        echo "${session}=${new_alias}" >> "$ALIAS_FILE"
    fi

    echo "renamed: $old_alias -> $new_alias  ($session)"
}

cmd_cull() {
    check_deps
    local mode="explicit"
    local older_than_hours=24
    local filter=""
    local limit=0
    local dry_run=0
    local -a requested=()
    local -a targets=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --stale) mode="stale"; shift ;;
            --older-than) [[ $# -ge 2 ]] || die "--older-than requires an hour count"; require_hours "$2"; older_than_hours="$2"; shift 2 ;;
            --filter) [[ $# -ge 2 ]] || die "--filter requires a pattern"; filter="$2"; shift 2 ;;
            --limit) [[ $# -ge 2 ]] || die "--limit requires a count"; require_int "$2"; limit="$2"; shift 2 ;;
            --dry-run) dry_run=1; shift ;;
            -*) die "unknown flag: $1" ;;
            *) requested+=("$1"); shift ;;
        esac
    done

    if [[ "$mode" == "stale" && "${#requested[@]}" -gt 0 ]]; then
        die "cannot mix explicit sessions with --stale"
    fi
    if [[ "$mode" == "explicit" && "${#requested[@]}" -eq 0 ]]; then
        die "usage: surrogate cull <session>... | surrogate cull --stale [--older-than HOURS] [--filter PATTERN] [--dry-run]"
    fi

    if [[ "$mode" == "stale" ]]; then
        local rows=""
        rows="$(stale_candidates "$older_than_hours" "$filter" "$limit")"
        if [[ -z "$rows" ]]; then
            echo "no stale sessions to cull"
            return 0
        fi
        while IFS=$'\t' read -r _age _alias session _snippet; do
            [[ -n "$session" ]] || continue
            targets+=("$session")
        done <<< "$rows"
    else
        local input session guard_reason
        for input in "${requested[@]}"; do
            session="$(resolve_session "$input")"
            if ! guard_reason="$(ensure_cullable_session "$session")"; then
                die "$guard_reason"
            fi
            targets+=("$session")
        done
    fi

    if [[ "${#targets[@]}" -eq 0 ]]; then
        echo "no sessions to cull"
        return 0
    fi

    _build_alias_cache
    local session alias age_label
    for session in "${targets[@]}"; do
        alias="${_ALIAS_CACHE[$session]:-$(session_alias "$session")}"
        age_label="$(format_age_secs "$(session_age_secs "$session" 2>/dev/null || echo 0)")"
        if [[ "$dry_run" -eq 1 ]]; then
            echo "would cull: $alias  $session  age=$age_label"
            continue
        fi
        cull_session "$session"
        echo "culled: $alias  $session  age=$age_label"
    done
}

cmd_bridge() {
    check_deps
    [[ $# -ge 1 ]] || die "usage: surrogate bridge <session>"
    local session
    session="$(resolve_session "$1")"
    ensure_bridge "$session"
    echo "bridge ready: $(bridge_name "$session")"
}

cmd_cleanup() {
    check_deps
    local mode="${1:---dead}"

    case "$mode" in
        --all)
            local sessions
            sessions="$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep "^${BRIDGE_PREFIX}" || true)"
            if [[ -z "$sessions" ]]; then
                echo "no bridges to clean up"
                return
            fi
            while IFS= read -r s; do
                tmux kill-session -t "$s" 2>/dev/null && echo "killed $s" || true
            done <<< "$sessions"
            ;;
        --dead|"")
            local sessions
            sessions="$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep "^${BRIDGE_PREFIX}" || true)"
            if [[ -z "$sessions" ]]; then
                echo "no bridges to clean up"
                return
            fi
            while IFS= read -r s; do
                local zmx_name="${s#"$BRIDGE_PREFIX"}"
                if ! session_exists "$zmx_name"; then
                    tmux kill-session -t "$s" 2>/dev/null && echo "killed $s (zmx session gone)" || true
                fi
            done <<< "$sessions"
            ;;
        *)
            die "unknown flag: $mode (use --all or --dead)"
            ;;
    esac
}

cmd_status() {
    check_deps
    local sessions
    sessions="$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep "^${BRIDGE_PREFIX}" || true)"

    if [[ -z "$sessions" ]]; then
        echo "no active bridges"
        return
    fi

    printf "%-50s %s\n" "BRIDGE" "STATUS"
    while IFS= read -r s; do
        local zmx_name="${s#"$BRIDGE_PREFIX"}"
        local status
        if session_exists "$zmx_name"; then
            status="ok"
        else
            status="DEAD (zmx session gone)"
        fi
        printf "%-50s %s\n" "$s" "$status"
    done <<< "$sessions"
}

# --- main ---

[[ $# -eq 0 ]] && usage

case "${1}" in
    list)    shift; cmd_list "$@" ;;
    stale)   shift; cmd_stale "$@" ;;
    send)    shift; cmd_send "$@" ;;
    submit)  shift; cmd_submit "$@" ;;
    type)    shift; cmd_type "$@" ;;
    read)    shift; cmd_read "$@" ;;
    wait)    shift; cmd_wait "$@" ;;
    find)    shift; cmd_find "$@" ;;
    who)     shift; cmd_who "$@" ;;
    active)  shift; cmd_active "$@" ;;
    peek)    shift; cmd_peek "$@" ;;
    alias)   shift; cmd_alias "$@" ;;
    whoami)  shift; cmd_whoami "$@" ;;
    rename)  shift; cmd_rename "$@" ;;
    cull)    shift; cmd_cull "$@" ;;
    bridge)  shift; cmd_bridge "$@" ;;
    cleanup) shift; cmd_cleanup "$@" ;;
    status)  shift; cmd_status "$@" ;;
    help|-h|--help) shift || true; cmd_help "$@" ;;
    *)       die "unknown command: $1" ;;
esac
