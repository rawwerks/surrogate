#!/usr/bin/env bash
set -euo pipefail

MARKER_BEGIN="# surrogate:zmx:begin"
MARKER_END="# surrogate:zmx:end"

usage() {
  cat <<'EOF'
surrogate-shell-setup — install/manage auto-zmx for interactive terminals

Usage:
  surrogate-shell-setup [--show]      Show the snippet for your shell (default)
  surrogate-shell-setup --install     Install or refresh the managed snippet in your shell rc file
  surrogate-shell-setup --uninstall   Remove snippet from your shell rc file
  surrogate-shell-setup --check       Check if snippet is already installed
  surrogate-shell-setup --help        Show this help

Environment:
  SURROGATE_NO_ZMX=1   Set in any session to skip auto-zmx
  ZMX_SESSION           Set automatically by zmx (prevents double-wrapping)
EOF
}

detect_shell() {
  local sh
  sh="$(basename "${SHELL:-/bin/bash}")"
  case "$sh" in
    bash|zsh|fish) echo "$sh" ;;
    *) echo "bash" ;;  # fallback
  esac
}

rc_file_for() {
  case "$1" in
    bash) echo "$HOME/.bashrc" ;;
    zsh)  echo "$HOME/.zshrc" ;;
    fish) echo "$HOME/.config/fish/config.fish" ;;
  esac
}

snippet_for() {
  case "$1" in
    bash|zsh)
      cat <<'SNIPPET'
# surrogate:zmx:begin
# surrogate: auto-zmx for all interactive terminals
# Uses full path to zmx — this runs before PATH is configured in .bashrc.
# Checks parent process to avoid double-wrapping (env var leaks to children).
# INVARIANT: Always prints "surrogate:" status line, regardless of terminal app.
if [[ -z "${SURROGATE_NO_ZMX:-}" && $- == *i* ]]; then
  _surr_zmx="${ZMX_BIN:-$HOME/.local/bin/zmx}"
  _surr_surrogate="${SURROGATE_BIN:-$HOME/.local/bin/surrogate}"
  if [[ -x "$_surr_zmx" ]]; then
    zmx() {
      local _surr_real_zmx="${ZMX_BIN:-$HOME/.local/bin/zmx}"
      if [[ ! -x "$_surr_real_zmx" ]]; then
        command zmx "$@"
        return
      fi
      case "${1:-}" in
        attach|a)
          env -u ZMX_SESSION "$_surr_real_zmx" "$@"
          ;;
        *)
          "$_surr_real_zmx" "$@"
          ;;
      esac
    }
    _surr_parent="$(ps -o comm= -p $PPID 2>/dev/null)"
    if [[ "$_surr_parent" != "zmx" ]]; then
      _surr_name="$(date +'%Y-%m-%d_%H-%M-%S_%Z')-$$"
      echo "surrogate: wrapping in zmx session $_surr_name"
      unset ZMX_SESSION
      exec "$_surr_zmx" attach "$_surr_name"
    else
      _surr_alias=""
      _surr_path="$(dirname "$_surr_surrogate"):$(dirname "$_surr_zmx"):${PATH:-/usr/bin:/bin}"
      if [[ -n "${ZMX_SESSION:-}" && -x "$_surr_surrogate" ]]; then
        _surr_alias="$(PATH="$_surr_path" "$_surr_surrogate" alias "$ZMX_SESSION" 2>/dev/null || true)"
      fi
      if [[ -n "$_surr_alias" ]]; then
        echo "surrogate: zmx session ${ZMX_SESSION:-inherited} alias $_surr_alias"
      else
        echo "surrogate: zmx session ${ZMX_SESSION:-inherited}"
      fi
    fi
    unset _surr_alias _surr_parent _surr_path _surr_surrogate _surr_zmx
  fi
fi
# surrogate:zmx:end
SNIPPET
      ;;
    fish)
      cat <<'SNIPPET'
# surrogate:zmx:begin
# surrogate: auto-zmx for all interactive terminals
# INVARIANT: Always prints "surrogate:" status line, regardless of terminal app.
if not set -q SURROGATE_NO_ZMX; and status is-interactive
  set -l _surr_zmx (set -q ZMX_BIN; and echo $ZMX_BIN; or echo $HOME/.local/bin/zmx)
  set -l _surr_surrogate (set -q SURROGATE_BIN; and echo $SURROGATE_BIN; or echo $HOME/.local/bin/surrogate)
  if test -x "$_surr_zmx"
    function zmx --description 'surrogate nested zmx attach shim'
      set -l _surr_real_zmx (set -q ZMX_BIN; and echo $ZMX_BIN; or echo $HOME/.local/bin/zmx)
      if not test -x "$_surr_real_zmx"
        command zmx $argv
        return $status
      end
      if test (count $argv) -ge 1
        switch "$argv[1]"
          case attach a
            env -u ZMX_SESSION "$_surr_real_zmx" $argv
            return $status
        end
      end
      "$_surr_real_zmx" $argv
      return $status
    end
    set -l _surr_parent (ps -o comm= -p %self 2>/dev/null)
    if test "$_surr_parent" != "zmx"
      set -l _surr_name (date +'%Y-%m-%d_%H-%M-%S_%Z')"-$fish_pid"
      echo "surrogate: wrapping in zmx session $_surr_name"
      set -e ZMX_SESSION
      exec $_surr_zmx attach $_surr_name
    else
      set -l _surr_session (set -q ZMX_SESSION; and echo $ZMX_SESSION; or echo "inherited")
      set -l _surr_alias ""
      set -l _surr_path (dirname "$_surr_surrogate")":"(dirname "$_surr_zmx")":"(string join ":" $PATH)
      if set -q ZMX_SESSION; and test -x "$_surr_surrogate"
        set _surr_alias (env PATH="$_surr_path" $_surr_surrogate alias "$ZMX_SESSION" 2>/dev/null)
      end
      if test -n "$_surr_alias"
        echo "surrogate: zmx session $_surr_session alias $_surr_alias"
      else
        echo "surrogate: zmx session $_surr_session"
      end
    end
  end
end
# surrogate:zmx:end
SNIPPET
      ;;
  esac
}

is_installed() {
  local rc="$1"
  [[ -f "$rc" ]] && grep -qF "$MARKER_BEGIN" "$rc"
}

current_managed_block() {
  local rc="$1"
  [[ -f "$rc" ]] || return 0
  awk -v begin="$MARKER_BEGIN" -v end="$MARKER_END" '
    $0 == begin { print; capture=1; next }
    capture {
      print
      if ($0 == end) {
        exit
      }
    }
  ' "$rc"
}

render_without_managed_block() {
  local rc="$1"
  [[ -f "$rc" ]] || return 0
  awk -v begin="$MARKER_BEGIN" -v end="$MARKER_END" '
    $0 == begin { skip=1; next }
    $0 == end   { skip=0; getline; if ($0 != "") print; next }
    !skip       { print }
  ' "$rc"
}

do_show() {
  local sh="$1"
  local rc
  rc="$(rc_file_for "$sh")"
  echo "Shell:   $sh"
  echo "RC file: $rc"
  echo ""
  echo "Snippet that would be added:"
  echo "---"
  snippet_for "$sh"
  echo "---"
}

do_check() {
  local sh="$1"
  local rc
  rc="$(rc_file_for "$sh")"
  if is_installed "$rc"; then
    echo "Installed in $rc"
    return 0
  else
    echo "Not installed in $rc"
    return 1
  fi
}

do_install() {
  local sh="$1"
  local rc
  local desired
  local current=""
  local action="Installed"
  rc="$(rc_file_for "$sh")"
  desired="$(snippet_for "$sh")"

  # Ensure rc file and parent dirs exist
  mkdir -p "$(dirname "$rc")"
  touch "$rc"

  if is_installed "$rc"; then
    current="$(current_managed_block "$rc")"
    if [[ "$current" == "$desired" ]]; then
      echo "Already installed in $rc — nothing to do."
      return 0
    fi
    action="Updated"
  fi

  # Prepend snippet to rc file (it must run early, before other config).
  local tmp
  tmp="$(mktemp)"
  {
    printf '%s\n' "$desired"
    echo ""
    render_without_managed_block "$rc"
  } > "$tmp"

  mv "$tmp" "$rc"
  echo "$action auto-zmx snippet at top of $rc"
}

do_uninstall() {
  local sh="$1"
  local rc
  rc="$(rc_file_for "$sh")"

  if ! is_installed "$rc"; then
    echo "Not installed in $rc — nothing to do."
    return 0
  fi

  local tmp
  tmp="$(mktemp)"

  render_without_managed_block "$rc" > "$tmp"

  mv "$tmp" "$rc"
  echo "Removed auto-zmx snippet from $rc"
}

main() {
  local action="show"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --show)      action="show"; shift ;;
      --install)   action="install"; shift ;;
      --uninstall) action="uninstall"; shift ;;
      --check)     action="check"; shift ;;
      --help|-h)   usage; exit 0 ;;
      *)
        echo "Unknown option: $1" >&2
        usage >&2
        exit 1
        ;;
    esac
  done

  local sh
  sh="$(detect_shell)"

  case "$action" in
    show)      do_show "$sh" ;;
    check)     do_check "$sh" ;;
    install)   do_install "$sh" ;;
    uninstall) do_uninstall "$sh" ;;
  esac
}

main "$@"
