#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

SURROGATE_TMP="/tmp"
BRIDGE_PREFIX="_surr_"
ALIAS_FILE="${SURROGATE_TMP}/surrogate-aliases"
AUDIT_FILE="${SURROGATE_AUDIT_FILE:-${SURROGATE_TMP}/surrogate-audit.jsonl}"
SURROGATE_LABEL="${SURROGATE_LABEL:-on}"  # on | off | verbose
SURROGATE_TYPE_ENTER_DELAY_SECS="${SURROGATE_TYPE_ENTER_DELAY_SECS:-0.02}"
SURROGATE_TYPE_POSTCHECK_SECS="${SURROGATE_TYPE_POSTCHECK_SECS:-0.15}"

# --- helpers (needed early) ---

die() { echo "surrogate: error: $*" >&2; exit 1; }
warn() { echo "surrogate: warning: $*" >&2; }

require_int() {
    # Validate that $1 is a non-negative integer
    [[ "$1" =~ ^[0-9]+$ ]] || die "'$1' is not a valid number"
}

require_seconds() {
    [[ "$1" =~ ^[0-9]+([.][0-9]+)?$ ]] || die "'$1' is not a valid seconds value"
}

require_hours() {
    [[ "$1" =~ ^[0-9]+$ ]] || die "'$1' is not a valid hour count"
}

check_deps() {
    command -v zmx >/dev/null 2>&1 || die "zmx not found. Install zmx first."
    command -v tmux >/dev/null 2>&1 || die "tmux not found. Install with your package manager."
}

session_exists() {
    zmx list 2>/dev/null | grep -q "^session_name=$1	"
}

_session_names() {
    local line session
    while IFS= read -r line; do
        session="${line#session_name=}"
        session="${session%%$'\t'*}"
        [[ -n "$session" ]] && printf '%s\n' "$session"
    done < <(zmx list 2>/dev/null)
}

session_clients() {
    local target="$1"
    local line session clients
    while IFS= read -r line; do
        session="${line#session_name=}"
        session="${session%%$'\t'*}"
        [[ "$session" == "$target" ]] || continue
        clients="${line##*clients=}"
        clients="${clients%%$'\t'*}"
        echo "${clients:-0}"
        return 0
    done < <(zmx list 2>/dev/null)
    return 1
}

bridge_exists() {
    tmux has-session -t "$(bridge_name "$1")" 2>/dev/null
}

_search() {
    # Use rg if available, fall back to grep -E
    if command -v rg >/dev/null 2>&1; then
        rg "$@"
    else
        grep -E "$@"
    fi
}

normalize_type_text() {
    printf '%s' "$1" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//'
}

guard_send_keys() {
    local key
    for key in "$@"; do
        case "$key" in
            C-c|C-d|C-z)
                echo "dangerous control key '$key' is reserved for direct human control"
                return 1
                ;;
        esac
    done
}

json_escape() {
    printf '%s' "$1" | sed ':a;N;$!ba;s/\\/\\\\/g;s/"/\\"/g;s/\t/\\t/g;s/\r/\\r/g;s/\n/\\n/g'
}

current_repo_name() {
    local git_root=""
    if command -v git >/dev/null 2>&1 &&
       git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
        basename "$git_root"
    else
        basename "$PWD"
    fi
}

json_or_null() {
    if [[ -n "$1" ]]; then
        printf '"%s"' "$(json_escape "$1")"
    else
        printf 'null'
    fi
}

record_display_field() {
    if [[ -n "${1:-}" ]]; then
        printf '%s' "$1"
    else
        printf '%s' '-'
    fi
}

record_nullable_field() {
    if [[ "${1:-}" == "-" ]]; then
        printf '%s' ""
    else
        printf '%s' "${1:-}"
    fi
}

audit_event() {
    local action="$1" session="$2" decision="$3" detail="$4" reason="${5:-}"
    local ts detail_json reason_json
    local target_alias actor_session actor_alias repo_name work_id intent_reason
    ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    detail_json="$(json_escape "$detail")"
    reason_json="$(json_escape "$reason")"
    target_alias="$(session_alias "$session")"
    actor_session="${ZMX_SESSION:-}"
    actor_alias=""
    if [[ -n "$actor_session" ]]; then
        actor_alias="$(session_alias "$actor_session")"
    fi
    repo_name="$(current_repo_name)"
    work_id="${SURROGATE_WORK_ID:-}"
    intent_reason="${SURROGATE_REASON:-}"
    printf '{"ts":"%s","action":"%s","session":"%s","target_alias":"%s","decision":"%s","detail":"%s","reason":"%s","actor_session":"%s","actor_alias":"%s","work_id":"%s","intent_reason":"%s","repo":"%s"}\n' \
        "$ts" "$action" "$session" "$(json_escape "$target_alias")" "$decision" "$detail_json" "$reason_json" \
        "$(json_escape "$actor_session")" "$(json_escape "$actor_alias")" "$(json_escape "$work_id")" \
        "$(json_escape "$intent_reason")" "$(json_escape "$repo_name")" >> "$AUDIT_FILE"
}

scan_with_dcg() {
    local text="$1"
    command -v dcg >/dev/null 2>&1 || return 0

    local dcg_output="" dcg_rc=0 reason=""
    set +e
    dcg_output="$(dcg --robot test "$text" 2>/dev/null)"
    dcg_rc=$?
    set -e

    case "$dcg_rc" in
        0) return 0 ;;
        1)
            reason="$(printf '%s\n' "$dcg_output" | sed -n 's/.*"reason":"\([^"]*\)".*/\1/p')"
            [[ -n "$reason" ]] || reason="blocked by dcg"
            echo "dcg denied payload: $reason"
            return 1
            ;;
        *)
            # DCG is an optional layer; surrogate's built-in guardrails remain authoritative.
            return 0
            ;;
    esac
}

# --- alias wordlists (100 adjectives × 100 nouns = 10,000 combinations) ---

ADJECTIVES=(
    astral binary bouncy brave bright buzzy calm chrome clever cosmic
    cozy cubic cyber dandy deft dizzy dreamy dusty eager elfin
    fancy fizzy fleet fluffy foggy funky fuzzy gentle giddy glossy
    golden groovy happy hasty hex hollow holo idle ionic jazzy
    jolly keen kinetic lanky laser lazy light lunar lucky lumpy
    magic mellow merry micro misty nifty nimble noble nova odd
    perky pixel plucky polar prismy proxy pudgy quaint quick quirky
    radiant rapid retro robo rosy rusty sassy shiny silly sleek
    snappy snowy sonic sparkly speedy spicy spry starry sunny swift
    tidal tiny turbo twin vivid wacky warm whimsy wild zappy
)

NOUNS=(
    badger beagle beacon bison bolt bunny capybara cheetah chipmunk clank
    comet corgi coyote crane cricket cube cyborg dingo dolphin drone
    falcon ferret finch fox gadget gecko gizmo goose griffin hamster
    hawk heron husky iguana jackal kelpie koala lemur llama lynx
    mantis marmot meerkat moose moth narwhal newt osprey otter owl
    panda parrot pelican penguin photon pixel puffin quail quokka rabbit
    raven reindeer robin rover sabot seal sensor shrew signal sloth
    sparrow sphinx sprocket squid stork swift tapir thrush toucan urchin
    vector viper walrus weasel widget wombat wren yak zebra zippy
    axolotl bobcat camel chameleon condor ermine flamingo hedgehog ibis jellyfish
)

# --- alias functions ---

# Cache: built once per invocation, maps session→alias and alias→session
declare -A _ALIAS_CACHE _ALIAS_REVERSE
_ALIAS_CACHE_BUILT=""

_load_custom_aliases() {
    # Load custom aliases from file: session=alias (one per line)
    local -n _out="$1"
    [[ -f "$ALIAS_FILE" ]] || return 0
    local _sess _cust
    while IFS='=' read -r _sess _cust; do
        [[ -z "$_sess" || "$_sess" == \#* ]] && continue
        _out["$_sess"]="$_cust"
    done < "$ALIAS_FILE"
}

_build_alias_cache() {
    [[ -n "$_ALIAS_CACHE_BUILT" ]] && return
    _ALIAS_CACHE=()
    _ALIAS_REVERSE=()

    # Load custom aliases first
    local -A custom_aliases
    _load_custom_aliases custom_aliases

    local -a sorted_names
    while IFS= read -r name; do
        sorted_names+=("$name")
    done < <(_session_names | sort)

    # Compute aliases: custom overrides hash-derived
    local -A base_count
    local h i c s base cnt
    for name in "${sorted_names[@]}"; do
        if [[ -n "${custom_aliases[$name]:-}" ]]; then
            # Custom alias — use directly
            _ALIAS_CACHE["$name"]="${custom_aliases[$name]}"
            _ALIAS_REVERSE["${custom_aliases[$name]}"]="$name"
        else
            # Hash-derived alias
            s="$name" h=5381
            for (( i=0; i<${#s}; i++ )); do
                printf -v c '%d' "'${s:$i:1}"
                h=$(( ((h << 5) + h + c) & 0x7FFFFFFF ))
            done
            base="${ADJECTIVES[$((h % 100))]}-${NOUNS[$((h / 100 % 100))]}"
            cnt="${base_count[$base]:-0}"
            cnt=$((cnt + 1))
            base_count["$base"]=$cnt
            if [[ $cnt -eq 1 ]]; then
                _ALIAS_CACHE["$name"]="$base"
                _ALIAS_REVERSE["$base"]="$name"
            else
                _ALIAS_CACHE["$name"]="${base}-${cnt}"
                _ALIAS_REVERSE["${base}-${cnt}"]="$name"
            fi
        fi
    done
    _ALIAS_CACHE_BUILT=1
}

session_alias_base() {
    local name="$1" h=5381 i c
    for (( i=0; i<${#name}; i++ )); do
        printf -v c '%d' "'${name:$i:1}"
        h=$(( ((h << 5) + h + c) & 0x7FFFFFFF ))
    done
    echo "${ADJECTIVES[$((h % 100))]}-${NOUNS[$((h / 100 % 100))]}"
}

session_alias_single() {
    local name="$1"
    if [[ -n "$_ALIAS_CACHE_BUILT" && -n "${_ALIAS_CACHE[$name]:-}" ]]; then
        echo "${_ALIAS_CACHE[$name]}"
        return 0
    fi

    local custom_alias=""
    if [[ -f "$ALIAS_FILE" ]]; then
        custom_alias="$(awk -F= -v target="$name" '$1 == target { print $2; exit }' "$ALIAS_FILE" 2>/dev/null || true)"
        if [[ -n "$custom_alias" ]]; then
            echo "$custom_alias"
            return 0
        fi
    fi

    local base rank other
    base="$(session_alias_base "$name")"
    rank=0
    while IFS= read -r other; do
        [[ -n "$other" ]] || continue
        [[ "$(session_alias_base "$other")" == "$base" ]] || continue
        if [[ "$other" < "$name" || "$other" == "$name" ]]; then
            rank=$((rank + 1))
        fi
    done < <(_session_names)

    if [[ "$rank" -le 1 ]]; then
        echo "$base"
    else
        echo "${base}-${rank}"
    fi
}

session_alias() {
    _build_alias_cache
    if [[ -n "${_ALIAS_CACHE[$1]:-}" ]]; then
        echo "${_ALIAS_CACHE[$1]}"
        return 0
    fi

    session_alias_single "$1"
}

resolve_session() {
    local input="$1"

    # 1. Exact match — always wins
    if session_exists "$input"; then
        echo "$input"
        return 0
    fi

    # 2. Alias lookup from reverse cache
    _build_alias_cache
    if [[ -n "${_ALIAS_REVERSE[$input]:-}" ]]; then
        echo "${_ALIAS_REVERSE[$input]}"
        return 0
    fi

    die "session '$input' not found (not a name or alias)"
}

proc_self_pid() {
    echo "${SURROGATE_SELF_PID:-$$}"
}

proc_ppid() {
    local pid="$1"
    local proc_root="${SURROGATE_PROC_ROOT:-/proc}"
    [[ -r "$proc_root/$pid/stat" ]] || return 1
    awk '{print $4}' "$proc_root/$pid/stat"
}

proc_cmdline() {
    local pid="$1"
    local proc_root="${SURROGATE_PROC_ROOT:-/proc}"
    [[ -r "$proc_root/$pid/cmdline" ]] || return 1
    tr '\0' ' ' < "$proc_root/$pid/cmdline"
}

ancestry_zmx_attach_session() {
    local parent depth=0 cmd session
    parent="$(proc_ppid "$(proc_self_pid)" 2>/dev/null || true)"
    while [[ "$depth" -lt 24 && -n "$parent" && "$parent" =~ ^[0-9]+$ && "$parent" -gt 1 ]]; do
        cmd="$(proc_cmdline "$parent" 2>/dev/null || true)"
        if [[ "$cmd" == *"zmx attach "* ]]; then
            session="${cmd##*zmx attach }"
            session="${session%% *}"
            [[ -n "$session" ]] && {
                echo "$session"
                return 0
            }
        fi
        parent="$(proc_ppid "$parent" 2>/dev/null || true)"
        depth=$((depth + 1))
    done
    return 1
}

current_session_identity() {
    local env_session="${ZMX_SESSION:-}"
    local ancestry_session=""

    if [[ -n "$env_session" ]]; then
        if session_exists "$env_session"; then
            printf 'live\t%s\n' "$env_session"
            return 0
        fi
    fi

    ancestry_session="$(ancestry_zmx_attach_session 2>/dev/null || true)"
    if [[ -n "$ancestry_session" ]]; then
        if session_exists "$ancestry_session"; then
            printf 'live\t%s\n' "$ancestry_session"
        else
            printf 'ancestry\t%s\n' "$ancestry_session"
        fi
        return 0
    fi

    if [[ -n "$env_session" ]]; then
        printf 'stale-env\t%s\n' "$env_session"
        return 0
    fi

    return 1
}

current_live_session() {
    local status session
    IFS=$'\t' read -r status session < <(current_session_identity 2>/dev/null || true)
    [[ "$status" == "live" && -n "$session" ]] || return 1
    echo "$session"
}

guard_self_target() {
    local target_session="$1"
    local current_session=""
    current_session="$(current_live_session 2>/dev/null || true)"
    [[ -n "$current_session" ]] || return 0
    [[ "$current_session" != "$target_session" ]] || {
        _build_alias_cache
        local current_alias="${_ALIAS_CACHE[$current_session]:-$(session_alias "$current_session")}"
        echo "refusing to message your own live session. You are $current_alias ($current_session). Use direct input in this session instead."
        return 1
    }
}

guard_self_cull() {
    local target_session="$1"
    local current_session=""
    current_session="$(current_live_session 2>/dev/null || true)"
    [[ -n "$current_session" ]] || return 0
    [[ "$current_session" != "$target_session" ]] || {
        _build_alias_cache
        local current_alias="${_ALIAS_CACHE[$current_session]:-$(session_alias "$current_session")}"
        echo "refusing to prune your own live zmx session. You are $current_alias ($current_session). Detach or close it first."
        return 1
    }
}

zmx_socket_dir() {
    echo "/run/user/$(id -u)/zmx"
}

declare -A _SESSION_SOCKET_MTIME _SESSION_LOG_MTIME
_SESSION_TIME_CACHE_BUILT=""
_SESSION_TIME_CACHE_NOW=""

_build_session_time_cache() {
    [[ -n "$_SESSION_TIME_CACHE_BUILT" ]] && return
    _SESSION_SOCKET_MTIME=()
    _SESSION_LOG_MTIME=()
    _SESSION_TIME_CACHE_NOW="$(date +%s)"

    local socket_dir log_dir nullglob_state path mtime name
    socket_dir="$(zmx_socket_dir)"
    log_dir="$(zmx_log_dir)"
    nullglob_state="$(shopt -p nullglob || true)"
    shopt -s nullglob

    local -a socket_paths=("$socket_dir"/*)
    if [[ "${#socket_paths[@]}" -gt 0 ]]; then
        while IFS=$'\t' read -r path mtime; do
            [[ -n "$path" ]] || continue
            [[ -d "$path" ]] && continue
            name="${path##*/}"
            _SESSION_SOCKET_MTIME["$name"]="$mtime"
        done < <(stat -c $'%n\t%Y' "${socket_paths[@]}" 2>/dev/null || true)
    fi

    local -a log_paths=("$log_dir"/*.log)
    if [[ "${#log_paths[@]}" -gt 0 ]]; then
        while IFS=$'\t' read -r path mtime; do
            [[ -n "$path" ]] || continue
            name="${path##*/}"
            name="${name%.log}"
            _SESSION_LOG_MTIME["$name"]="$mtime"
        done < <(stat -c $'%n\t%Y' "${log_paths[@]}" 2>/dev/null || true)
    fi

    eval "$nullglob_state"
    _SESSION_TIME_CACHE_BUILT=1
}

session_age_secs() {
    local session="$1"
    local now mtime
    _build_session_time_cache
    mtime="${_SESSION_SOCKET_MTIME[$session]:-}"
    [[ -n "$mtime" ]] || {
        echo 0
        return 0
    }
    now="$_SESSION_TIME_CACHE_NOW"
    if [[ "$mtime" -gt "$now" ]]; then
        echo 0
    else
        echo $(( now - mtime ))
    fi
}

format_age_secs() {
    local age="$1"
    if [[ "$age" -lt 60 ]]; then
        echo "${age}s"
    elif [[ "$age" -lt 3600 ]]; then
        echo "$((age / 60))m"
    elif [[ "$age" -lt 86400 ]]; then
        echo "$((age / 3600))h"
    else
        echo "$((age / 86400))d"
    fi
}

session_snippet() {
    local session="$1"
    local lines="${2:-5}"
    zmx history "$session" 2>/dev/null | tail -n "$lines" | sed '/^[[:space:]]*$/d' | tail -1 | tr '\t' ' ' | cut -c1-60
}

remove_custom_alias() {
    local session="$1"
    [[ -f "$ALIAS_FILE" ]] || return 0
    local tmp
    tmp="$(mktemp)"
    awk -F= -v target="$session" '$1 != target { print $0 }' "$ALIAS_FILE" > "$tmp"
    mv "$tmp" "$ALIAS_FILE"
    _ALIAS_CACHE_BUILT=""
}

remove_session_plumbing() {
    local session="$1"
    tmux kill-session -t "$(bridge_name "$session")" 2>/dev/null || true
    rm -f "$(lock_file "$session")" "$(watermark_file "$session")"
    remove_custom_alias "$session"
}

count_rows() {
    local rows="${1:-}"
    if [[ -z "$rows" ]]; then
        echo 0
    else
        printf '%s\n' "$rows" | sed '/^$/d' | wc -l
    fi
}

take_nonempty_rows() {
    local limit="$1"
    awk -v limit="$limit" 'NF { print; count++; if (count >= limit) exit }'
}

session_review_row() {
    local session="$1"
    local age alias snippet
    age="$(session_age_secs "$session")"
    _build_alias_cache
    alias="${_ALIAS_CACHE[$session]:-$(session_alias "$session")}"
    snippet="$(session_snippet "$session" 5)"
    printf '%s\t%s\t%s\t%s\n' "$age" "$alias" "$session" "$snippet"
}

bridge_count_for_rows() {
    local rows="${1:-}"
    local count=0
    local _age _alias session _snippet
    while IFS=$'\t' read -r _age _alias session _snippet; do
        [[ -n "$session" ]] || continue
        if bridge_exists "$session"; then
            count=$((count + 1))
        fi
    done <<< "$rows"
    echo "$count"
}

stale_candidates() {
    local older_than_hours="$1"
    local filter="${2:-}"
    local limit="${3:-0}"
    local cutoff_secs=$((older_than_hours * 3600))
    local current_session=""
    local line session clients age alias snippet matched_basic prefer_basic_filter basic_sessions
    local rows=""

    current_session="$(current_live_session 2>/dev/null || true)"
    prefer_basic_filter=0
    basic_sessions=""

    if [[ -z "$filter" ]]; then
        _build_alias_cache
    else
        basic_sessions="$(_session_names | _search -i -- "$filter" 2>/dev/null || true)"
        if [[ -n "$basic_sessions" ]]; then
            prefer_basic_filter=1
        else
            _build_alias_cache
        fi
    fi

    if [[ -n "$filter" && "$prefer_basic_filter" -eq 0 ]]; then
        while IFS= read -r line; do
            session="$(echo "$line" | sed -n 's/^session_name=\([^\t]*\).*/\1/p')"
            [[ -n "$session" ]] || continue
            alias="${_ALIAS_CACHE[$session]:-$(session_alias "$session")}"
            if printf '%s\n' "$alias $session" | _search -qi -- "$filter" 2>/dev/null; then
                prefer_basic_filter=1
                basic_sessions+="$session"
                basic_sessions+=$'\n'
            fi
        done < <(zmx list 2>/dev/null)
    fi

    if [[ "$prefer_basic_filter" -eq 1 ]]; then
        rows="$(
            while IFS= read -r session; do
                [[ -n "$session" ]] || continue
                [[ "$session" != "$current_session" ]] || continue
                clients="$(session_effective_clients "$session")"
                [[ "${clients:-0}" -eq 0 ]] || continue
                age="$(session_age_secs "$session")"
                [[ "$age" -ge "$cutoff_secs" ]] || continue
                alias="${_ALIAS_CACHE[$session]:-$(session_alias_single "$session")}"
                snippet="$(session_snippet "$session" 5)"
                printf '%s\t%s\t%s\t%s\n' "$age" "$alias" "$session" "$snippet"
            done <<< "$basic_sessions" | sort -rn -k1,1
        )"
    else
        rows="$(
            while IFS= read -r line; do
                session="$(echo "$line" | sed -n 's/^session_name=\([^\t]*\).*/\1/p')"
                [[ -n "$session" ]] || continue
                [[ "$session" != "$current_session" ]] || continue
                clients="$(session_effective_clients "$session")"
                [[ "${clients:-0}" -eq 0 ]] || continue
                age="$(session_age_secs "$session")"
                [[ "$age" -ge "$cutoff_secs" ]] || continue
                alias="${_ALIAS_CACHE[$session]:-$(session_alias_single "$session")}"
                snippet=""
                if [[ -n "$filter" ]]; then
                    matched_basic=0
                    if printf '%s\n' "$alias $session" | _search -qi -- "$filter" 2>/dev/null; then
                        matched_basic=1
                    fi
                    if [[ "$matched_basic" -eq 0 ]]; then
                        snippet="$(session_snippet "$session" 5)"
                        if ! printf '%s\n' "$snippet" | _search -qi -- "$filter" 2>/dev/null; then
                            continue
                        fi
                    fi
                fi
                [[ -n "${snippet:-}" ]] || snippet="$(session_snippet "$session" 5)"
                printf '%s\t%s\t%s\t%s\n' "$age" "$alias" "$session" "$snippet"
            done < <(zmx list 2>/dev/null) | sort -rn -k1,1
        )"
    fi

    [[ -n "$rows" ]] || return 0
    if [[ "$limit" -gt 0 ]]; then
        printf '%s\n' "$rows" | take_nonempty_rows "$limit"
    else
        printf '%s\n' "$rows"
    fi
}

stale_skips() {
    local older_than_hours="$1"
    local filter="${2:-}"
    local cutoff_secs=$((older_than_hours * 3600))
    local current_session=""
    local line session clients age alias snippet reason matched_basic prefer_basic_filter basic_sessions
    local rows=""

    current_session="$(current_live_session 2>/dev/null || true)"
    prefer_basic_filter=0
    basic_sessions=""

    if [[ -z "$filter" ]]; then
        _build_alias_cache
    else
        basic_sessions="$(_session_names | _search -i -- "$filter" 2>/dev/null || true)"
        if [[ -n "$basic_sessions" ]]; then
            prefer_basic_filter=1
        else
            _build_alias_cache
        fi
    fi

    if [[ -n "$filter" && "$prefer_basic_filter" -eq 0 ]]; then
        while IFS= read -r line; do
            session="$(echo "$line" | sed -n 's/^session_name=\([^\t]*\).*/\1/p')"
            [[ -n "$session" ]] || continue
            alias="${_ALIAS_CACHE[$session]:-$(session_alias "$session")}"
            if printf '%s\n' "$alias $session" | _search -qi -- "$filter" 2>/dev/null; then
                prefer_basic_filter=1
                basic_sessions+="$session"
                basic_sessions+=$'\n'
            fi
        done < <(zmx list 2>/dev/null)
    fi

    if [[ "$prefer_basic_filter" -eq 1 ]]; then
        rows="$(
            while IFS= read -r session; do
                [[ -n "$session" ]] || continue
                age="$(session_age_secs "$session")"
                [[ "$age" -ge "$cutoff_secs" ]] || continue
                alias="${_ALIAS_CACHE[$session]:-$(session_alias_single "$session")}"
                snippet="$(session_snippet "$session" 5)"

                reason=""
                if [[ -n "$current_session" && "$session" == "$current_session" ]]; then
                    reason="current live session"
                else
                    clients="$(session_effective_clients "$session")"
                    if [[ "${clients:-0}" -gt 0 ]]; then
                        reason="${clients} attached client(s)"
                    fi
                fi

                [[ -n "$reason" ]] || continue
                printf '%s\t%s\t%s\t%s\t%s\n' "$age" "$alias" "$session" "$reason" "$snippet"
            done <<< "$basic_sessions" | sort -rn -k1,1
        )"
    else
        rows="$(
            while IFS= read -r line; do
                session="$(echo "$line" | sed -n 's/^session_name=\([^\t]*\).*/\1/p')"
                [[ -n "$session" ]] || continue
                age="$(session_age_secs "$session")"
                [[ "$age" -ge "$cutoff_secs" ]] || continue
                alias="${_ALIAS_CACHE[$session]:-$(session_alias_single "$session")}"
                snippet=""
                if [[ -n "$filter" ]]; then
                    matched_basic=0
                    if printf '%s\n' "$alias $session" | _search -qi -- "$filter" 2>/dev/null; then
                        matched_basic=1
                    fi
                    if [[ "$matched_basic" -eq 0 ]]; then
                        snippet="$(session_snippet "$session" 5)"
                        if ! printf '%s\n' "$snippet" | _search -qi -- "$filter" 2>/dev/null; then
                            continue
                        fi
                    fi
                fi
                [[ -n "${snippet:-}" ]] || snippet="$(session_snippet "$session" 5)"

                reason=""
                if [[ -n "$current_session" && "$session" == "$current_session" ]]; then
                    reason="current live session"
                else
                    clients="$(session_effective_clients "$session")"
                    if [[ "${clients:-0}" -gt 0 ]]; then
                        reason="${clients} attached client(s)"
                    fi
                fi

                [[ -n "$reason" ]] || continue
                printf '%s\t%s\t%s\t%s\t%s\n' "$age" "$alias" "$session" "$reason" "$snippet"
            done < <(zmx list 2>/dev/null) | sort -rn -k1,1
        )"
    fi

    [[ -n "$rows" ]] || return 0
    printf '%s\n' "$rows"
}

ensure_cullable_session() {
    local session="$1"
    local guard_reason=""
    local clients=""
    if ! guard_reason="$(guard_self_cull "$session")"; then
        echo "$guard_reason"
        return 1
    fi
    clients="$(session_effective_clients "$session")"
    if [[ "${clients:-0}" -gt 0 ]]; then
        echo "session '$session' has ${clients} client(s); detach it before pruning"
        return 1
    fi
}

prune_session() {
    local session="$1"
    zmx kill "$session" >/dev/null 2>&1 || die "failed to prune session '$session'"
    remove_session_plumbing "$session"
}

# --- remaining helpers ---

usage() {
    cat <<'EOF'
surrogate - deterministic terminal control for zmx sessions

Usage: surrogate <command> [args]

High-value flows:
  surrogate live --here              Show the live, actionable sessions for this repo
  surrogate help list                 Show discoverability-oriented list usage
  surrogate who --recent 20           Find the most recent interesting sessions
  surrogate brief --recent 15         Brief the 15 most recently active sessions
  surrogate sweep --older-than 48     Preview old detached zmx sessions to delete
  surrogate list --cwd                Show repo + cwd hints for every session
  surrogate type --message <session> "long prose"
                                      Safest way to send agent prose
  surrogate submit <session>          Recover a visibly staged prompt
  surrogate read <session> -n 40      Inspect what happened after a send/type

Commands:
  list  [-n LINES] [--cwd] [--json]
                                List sessions by alias; add --cwd/--json for repo and UI context
  stale [--older-than HOURS]    List old detached zmx sessions (default: 24h)
  send  <session> [keys...]     Send tmux send-keys style keystrokes
  submit <session>              Press Enter for a staged prompt
  type  [--message] <session> <text>
                                Type literal text followed by Enter
  read  <session> [-n LINES]    Read recent output (default: 20 lines)
  wait  <session> <pattern> [-t TIMEOUT]
                                Wait for regex pattern in new output (default: 30s)
  find  <query> [-n LINES]      Search all sessions for text (grep, default: last 200 lines)
  who   [-n LINES] [--recent N|2h] [--project NAME] [--cwd PATH] [--json]
                                Show sessions with age and last visible line
  live  [-n LINES] [--recent N|2h] [--project NAME|--here] [--cwd PATH] [--all] [--json]
                                Show only live, messageable sessions with less noise
  active [--all]                Show attached sessions (--all includes non-empty detached)
  brief [--recent N|2h] [filters] [session...]
                                Remote operator brief via surrogate-brief / OpenRouter
  sweep [--older-than HOURS] [--filter PATTERN] [--limit N] [--yes]
                                Preview or delete old detached zmx sessions in one flow
  prune-sessions <session>... [--dry-run]
  prune-sessions --stale [options]
                                Delete zmx sessions and clean their surrogate plumbing
  prune-bridges [--all|--dead]  Remove surrogate tmux bridges only
  peek  [-n LINES] [--filter PATTERN]
                                Batch read last N lines from all sessions (default: 5)
  alias <session>               Show the alias for a session
  whoami                        Show current session name and alias
  rename <session> <new-alias>  Set a custom alias (session ID stays the same)
  cull  ...                     Deprecated alias for prune-sessions
  bridge <session>              Pre-create tmux bridge for a zmx session
  cleanup [--all|--dead]        Deprecated alias for prune-bridges
  status                        Show bridge health

Session arguments accept either the full zmx name or the auto-generated alias.
Each session gets a deterministic adjective-noun alias (e.g. lazy-sheep).

Environment:
  SURROGATE_LABEL=on       Prepend [SURROGATE <alias>] to typed text (default)
  SURROGATE_LABEL=off      No prefix
  SURROGATE_LABEL=verbose  Include process name, cwd, PID in prefix
  SURROGATE_AUDIT_FILE     Audit log path (default: /tmp/surrogate-audit.jsonl)
  SURROGATE_TYPE_ENTER_DELAY_SECS
                          Fixed pause before Enter in `type` (default: 0.02)
  SURROGATE_TYPE_POSTCHECK_SECS
                          Fixed pause before shell failure warning check (default: 0.15)

Special keys (for send):
  Enter Escape Tab Space BSpace
  C-u C-l (Ctrl combos)
  Up Down Left Right

Examples:
  surrogate list
  surrogate help list
  surrogate live --here
  surrogate list --cwd
  surrogate stale --older-than 72 --limit 20
  surrogate sweep --older-than 48
  surrogate prune-sessions --stale --older-than 48 --dry-run
  surrogate prune-sessions --stale --older-than 48 --yes
  surrogate prune-sessions sleepy-otter
  surrogate prune-bridges --dead
  surrogate who --recent 2h --project surrogate
  surrogate live --recent 15
  surrogate live --here
  surrogate brief --recent 15
  surrogate brief 15
  surrogate brief silly-pixel
  surrogate who --cwd ~/Documents/GitHub/surrogate --json
  surrogate type --message lively-otter "Please review the patch plan above."
  surrogate submit lazy-sheep
  surrogate type lazy-sheep "echo hello"
  surrogate type 2026-03-08_15-07-15_EDT-132628 "echo hello"
  surrogate send my-session Escape ":wq" Enter
  surrogate read bold-crane -n 50
  surrogate alias 2026-03-08_15-07-15_EDT-132628

EOF
    exit 0
}

list_usage() {
    cat <<'EOF'
usage: surrogate list [-n LINES] [--cwd] [--json]

List every zmx session with deterministic aliasing. Use `--cwd` or `--json`
when you need visible repo/cwd/ui hints.

Options:
  -n LINES   Inspect this many recent history lines for repo/cwd/ui hints (default: 10)
  --cwd      Include full cwd hint column in text output
  --json     Emit machine-readable session metadata

Notes:
  - `project` and `cwd_hint` come from recent visible output, not process introspection.
  - `ui_hint` is a deterministic hint: `shell`, `agent`, or `unknown`.
EOF
}

who_usage() {
    cat <<'EOF'
usage: surrogate who [-n LINES] [--recent N|2h] [--project NAME] [--cwd PATH] [--json]

Show the newest sessions first by session age. By default, `who` shows the 20 most recent sessions.
Use `--recent N` or `--recent 2h` to widen or narrow the window.
For lower-noise activity-ranked discovery, use `surrogate live`.
EOF
}

live_usage() {
    cat <<'EOF'
usage: surrogate live [-n LINES] [--recent N|2h] [--project NAME|--here] [--cwd PATH] [--json]

Show only live, messageable zmx sessions. This is the low-noise discovery view:
- sessions must be present in `zmx list`
- sessions must have attached clients
- results are ranked by recent visible activity, not spawn time
- default output hides low-signal shell-like lanes with no visible repo/cwd hint

Add `--all` to include every live messageable session, including low-signal lanes.

Use `--here` to filter to the current repo name.
If the current shell is only ancestry-backed and not present in `zmx list`, `live`
prints a separate anomaly note instead of pretending that lane is messageable.
EOF
}

active_usage() {
    cat <<'EOF'
usage: surrogate active [--all] [-n LINES] [--recent N|2h] [--project NAME] [--cwd PATH] [--json]

Show sessions ranked by last observed activity (recent output), not creation time.
Default mode shows only attached sessions. Use --all to include detached sessions with visible output.
For a lower-noise, actually messageable view, use `surrogate live`.
EOF
}

brief_usage() {
    cat <<'EOF'
usage: surrogate brief [--recent N|2h] [--project NAME] [--cwd PATH] [--all] [brief-flags] [session...]

Triage and summarize sessions with one remote brief per session.

Selection rules:
  - If you pass explicit session names or aliases, those sessions are briefed.
  - Otherwise, session selection reuses `surrogate live --json`, which shows only
    live, messageable sessions ranked by last observed activity.
  - `surrogate brief 15` is shorthand for `surrogate brief --recent 15`.

Examples:
  surrogate brief --recent 15
  surrogate brief 15
  surrogate brief --project surrogate --recent 5
  surrogate brief silly-pixel
  surrogate brief --openrouter-model openai/gpt-4.1-mini --inference-provider openai silly-pixel

Brief flags are forwarded to `surrogate-brief`, including:
  --config, --no-config, --show-config, -n, --model, --openrouter-model,
  --llm-model, --provider, --inference-provider, --no-fallbacks,
  --temperature, --max-completion-tokens, --api-url
EOF
}

prune_sessions_usage() {
    cat <<'EOF'
usage: surrogate prune-sessions <session>... [--dry-run]
       surrogate prune-sessions --stale [--older-than HOURS] [--filter PATTERN] [--limit N] [--dry-run|--yes]

Delete zmx sessions and clean surrogate plumbing for those same sessions.

Modes:
  explicit targets  Deletes the named sessions or aliases. Use --dry-run to preview.
  --stale batch     Selects old detached zmx sessions. Preview is the default.
                    Re-run with --yes to execute deletion.

Notes:
  - Batch stale pruning reports old sessions skipped because they are still attached
    or because they are your current live session.
  - For bridge-only cleanup, use `surrogate prune-bridges`.
  - `surrogate cull` is a deprecated alias for this command.
EOF
}

prune_bridges_usage() {
    cat <<'EOF'
usage: surrogate prune-bridges [--dead|--all]

Remove surrogate tmux bridges only. This does not delete zmx sessions.

Options:
  --dead   Remove surrogate tmux bridges whose zmx sessions no longer exist (default)
  --all    Remove all surrogate tmux bridges

Note:
  `surrogate cleanup` is a deprecated alias for this command.
EOF
}

sweep_usage() {
    cat <<'EOF'
usage: surrogate sweep [--older-than HOURS] [--filter PATTERN] [--limit N] [--yes]

Preview or delete old detached zmx sessions in one flow.

Default behavior shows what would be deleted and what would be skipped.
Add --yes to actually delete the zmx sessions and remove their surrogate bridges.
EOF
}

type_usage() {
    cat <<'EOF'
usage: surrogate type [--message] <session> <text>

Modes:
  default     Literal text + Enter. Shell-safe by default: if target looks like a shell,
              Surrogate suppresses the prose prefix and warns if the shell immediately
              reports command-not-found or syntax errors.
  --message   Agent-message mode. Normalizes long prose and requires an agent-like target.
              Refuses shell and unknown targets to avoid accidental command execution.

Recovery:
  If text is visibly staged and only Enter is missing, run:
    surrogate submit <session>
EOF
}

send_usage() {
    cat <<'EOF'
usage: surrogate send <session> <keys...>

Send tmux-style keys directly. Use this for Enter, Escape, arrows, or manual repair.
Dangerous control keys C-c, C-d, and C-z are intentionally blocked.
EOF
}

submit_usage() {
    cat <<'EOF'
usage: surrogate submit <session>

Press Enter for a visibly staged prompt. This is the one obvious repair path when
text has landed in the target input but was not submitted.
EOF
}

cmd_help() {
    case "${1:-}" in
        ""|-h|--help) usage ;;
        list) list_usage ;;
        who) who_usage ;;
        active) active_usage ;;
        live) live_usage ;;
        brief) brief_usage ;;
        prune-sessions) prune_sessions_usage ;;
        prune-bridges) prune_bridges_usage ;;
        sweep) sweep_usage ;;
        type) type_usage ;;
        send) send_usage ;;
        submit) submit_usage ;;
        stale) echo "usage: surrogate stale [--older-than HOURS] [--filter PATTERN] [--limit N]" ;;
        cull) echo "usage: surrogate cull ...  # deprecated alias for prune-sessions" ;;
        cleanup) echo "usage: surrogate cleanup [--all|--dead]  # deprecated alias for prune-bridges" ;;
        *) die "unknown help topic: $1" ;;
    esac
}

brief_cmd_path() {
    if [[ -n "${SURROGATE_BRIEF_CMD:-}" ]]; then
        printf '%s\n' "$SURROGATE_BRIEF_CMD"
        return 0
    fi
    if command -v surrogate-brief >/dev/null 2>&1; then
        command -v surrogate-brief
        return 0
    fi
    if [[ -x "$SCRIPT_DIR/surrogate-brief" ]]; then
        printf '%s\n' "$SCRIPT_DIR/surrogate-brief"
        return 0
    fi
    die "surrogate-brief not found. Run: bash install.sh"
}

bridge_name() {
    echo "${BRIDGE_PREFIX}${1}"
}

lock_file() {
    echo "${SURROGATE_TMP}/surrogate-${1}.lock"
}

watermark_file() {
    echo "${SURROGATE_TMP}/surrogate-${1}.watermark"
}

line_count() {
    zmx history "$1" 2>/dev/null | wc -l
}

session_age_seconds() {
    local session="$1"
    local now mtime
    _build_session_time_cache
    mtime="${_SESSION_SOCKET_MTIME[$session]:-}"
    if [[ -n "$mtime" ]]; then
        now="$_SESSION_TIME_CACHE_NOW"
        echo $(( now - mtime ))
    else
        echo 2147483647
    fi
}

format_age() {
    local age="$1"
    if [[ "$age" -lt 60 ]]; then printf '%ss' "$age"
    elif [[ "$age" -lt 3600 ]]; then printf '%sm' $(( age / 60 ))
    elif [[ "$age" -lt 86400 ]]; then printf '%sh' $(( age / 3600 ))
    else printf '%sd' $(( age / 86400 )); fi
}

format_age_into() {
    local __var_name="$1"
    local age="$2"
    if [[ "$age" -lt 60 ]]; then
        printf -v "$__var_name" '%ss' "$age"
    elif [[ "$age" -lt 3600 ]]; then
        printf -v "$__var_name" '%sm' $(( age / 60 ))
    elif [[ "$age" -lt 86400 ]]; then
        printf -v "$__var_name" '%sh' $(( age / 3600 ))
    else
        printf -v "$__var_name" '%sd' $(( age / 86400 ))
    fi
}

zmx_log_dir() {
    echo "$(zmx_socket_dir)/logs"
}

session_log_path() {
    local session="$1"
    printf '%s/%s.log\n' "$(zmx_log_dir)" "$session"
}

session_activity_seconds() {
    local session="$1"
    local now mtime
    _build_session_time_cache
    now="$_SESSION_TIME_CACHE_NOW"
    mtime="${_SESSION_LOG_MTIME[$session]:-}"
    if [[ -n "$mtime" ]]; then
        echo $(( now - mtime ))
        return 0
    fi
    session_age_seconds "$session"
}

session_recent_history() {
    local session="$1" lines="$2"
    local log_path history
    if [[ "$lines" -eq 0 ]]; then
        return 0
    fi
    log_path="$(session_log_path "$session")"
    if [[ -r "$log_path" ]]; then
        history="$({ tail -n "$(( lines * 20 ))" "$log_path" 2>/dev/null | grep -Ev '^\[[0-9]+\] \[(info|debug|trace)\]' || true; } | tail -n "$lines")"
        if [[ -n "$history" ]]; then
            printf '%s\n' "$history"
            return 0
        fi
    fi
    zmx history "$session" 2>/dev/null | tail -n "$lines"
}

session_base_records() {
    _build_alias_cache
    _build_session_time_cache

    local line session clients age_seconds ago attached activity_seconds active_ago
    local now socket_mtime log_mtime
    now="$_SESSION_TIME_CACHE_NOW"
    while IFS= read -r line; do
        session="${line#session_name=}"
        session="${session%%$'\t'*}"
        clients="${line##*clients=}"
        clients="${clients%%$'\t'*}"
        [[ -n "$session" ]] || continue
        [[ -n "$clients" ]] || clients=0

        socket_mtime="${_SESSION_SOCKET_MTIME[$session]:-}"
        if [[ -n "$socket_mtime" ]]; then
            age_seconds=$(( now - socket_mtime ))
        else
            age_seconds=2147483647
        fi

        log_mtime="${_SESSION_LOG_MTIME[$session]:-}"
        if [[ -n "$log_mtime" ]]; then
            activity_seconds=$(( now - log_mtime ))
        else
            activity_seconds="$age_seconds"
        fi

        format_age_into ago "$age_seconds"
        format_age_into active_ago "$activity_seconds"
        attached="detached"
        [[ "$clients" -gt 0 ]] && attached="attached"

        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
            "$age_seconds" "$ago" "$attached" "$clients" "${_ALIAS_CACHE[$session]:-$(session_alias "$session")}" "$session" "$activity_seconds" "$active_ago"
    done < <(zmx list 2>/dev/null)
}

session_log_context() {
    local session="$1" lines="${2:-10}"
    local log_path history snippet cwd_hint project_hint ui_hint
    log_path="$(session_log_path "$session")"
    [[ -r "$log_path" ]] || return 1
    history="$({ tail -n "$(( lines * 100 ))" "$log_path" 2>/dev/null | grep -Ev '^\[[0-9]+\] \[(info|debug|trace)\]' || true; } | tail -n "$lines")"
    snippet="$(visible_snippet "$history")"
    cwd_hint="$(visible_path_hint "$history")"
    project_hint="$(project_from_path "$cwd_hint")"
    ui_hint="$(ui_hint_from_history "$history")"
    printf '%s\t%s\t%s\t%s\n' \
        "$(record_display_field "$snippet")" \
        "$(record_display_field "$cwd_hint")" \
        "$(record_display_field "$project_hint")" \
        "$ui_hint"
}

session_visible_context() {
    local session="$1" lines="${2:-10}"
    local history snippet cwd_hint project_hint ui_hint

    history="$(session_recent_history "$session" "$lines")"
    snippet="$(visible_snippet "$history")"
    cwd_hint="$(visible_path_hint "$history")"
    project_hint="$(project_from_path "$cwd_hint")"
    ui_hint="$(ui_hint_from_history "$history")"

    printf '%s\t%s\t%s\t%s\n' \
        "$(record_display_field "$snippet")" \
        "$(record_display_field "$cwd_hint")" \
        "$(record_display_field "$project_hint")" \
        "$ui_hint"
}

visible_snippet() {
    local text="$1"
    printf '%s' "$text" | sed '/^[[:space:]]*$/d' | tail -1 | tr '\t\r\n' '   ' | cut -c1-60
}

last_visible_line() {
    printf '%s\n' "$1" | sed '/^[[:space:]]*$/d' | tail -1
}

visible_path_hint() {
    local text="$1"
    { printf '%s\n' "$text" |
        grep -oE '((~|/)[^[:space:]]*/[^[:space:]]+)' 2>/dev/null |
        sed 's#[,;:.)\]}]+$##' || true; } |
        tail -1
}

project_from_path() {
    [[ -n "${1:-}" ]] || return 0
    basename "${1%/}"
}

ui_hint_from_history() {
    local text="$1"
    local last_line=""
    last_line="$(last_visible_line "$text")"

    if printf '%s\n' "$text" | grep -Eqi '^[[:space:]]*[›•✻]' ||
       printf '%s\n' "$text" | grep -Eqi 'Use /skills to list available skills|Model interrupted|[0-9]+% left|tokens left|background terminal running|Worked for [0-9]+m'; then
        echo "agent"
        return 0
    fi

    if [[ -n "$last_line" ]] &&
       printf '%s\n' "$last_line" | grep -Eq '([#$%>] ?|❯ ?)$'; then
        echo "shell"
        return 0
    fi

    echo "unknown"
}

shell_error_reason() {
    local text="$1"
    local match=""
    match="$(
        printf '%s\n' "$text" |
            grep -Ei -m1 'command not found|syntax error|unexpected EOF|unexpected token|No such file or directory|parse error|not a valid identifier' ||
            true
    )"
    [[ -n "$match" ]] || return 1
    printf '%s' "$match" | tr '\t\r\n' '   ' | cut -c1-120
}

session_records() {
    local lines="${1:-10}"
    local base_rows="${2:-}"
    local age_seconds ago attached clients alias session activity_seconds active_ago snippet cwd_hint project_hint ui_hint

    if [[ -z "$base_rows" ]]; then
        base_rows="$(session_base_records)"
    fi

    while IFS=$'\t' read -r age_seconds ago attached clients alias session activity_seconds active_ago; do
        [[ -n "$session" ]] || continue
        IFS=$'\t' read -r snippet cwd_hint project_hint ui_hint < <(session_visible_context "$session" "$lines")
        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
            "$age_seconds" "$ago" "$attached" "$clients" "$alias" \
            "$session" "$activity_seconds" "$active_ago" "$snippet" "$cwd_hint" "$project_hint" "$ui_hint"
    done <<< "$base_rows"
}

activity_ranked_records() {
    local mode="$1"
    local lines="${2:-10}"
    local recent_count="${3:-20}"
    local recent_age_max="${4:-}"
    local project_filter="${5:-}"
    local cwd_filter="${6:-}"
    local base_records filtered_base sorted_base selected_base records

    base_records="$(session_base_records)"
    filtered_base=""
    while IFS=$'\t' read -r age_seconds ago attached clients alias session activity_seconds active_ago; do
        [[ -n "$session" ]] || continue
        case "$mode" in
            live|attached)
                [[ "$clients" -gt 0 ]] || continue
                ;;
            all)
                local log_path lc
                log_path="$(session_log_path "$session")"
                if [[ -r "$log_path" ]]; then
                    [[ -s "$log_path" ]] || continue
                else
                    lc="$(zmx history "$session" 2>/dev/null | wc -l)"
                    [[ "$lc" -eq 0 ]] && continue
                fi
                ;;
            *)
                die "unknown activity-ranked mode: $mode"
                ;;
        esac
        if [[ -n "$recent_age_max" && "$activity_seconds" -gt "$recent_age_max" ]]; then
            continue
        fi
        filtered_base+=$(printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s' \
            "$age_seconds" "$ago" "$attached" "$clients" "$alias" "$session" "$activity_seconds" "$active_ago")
        filtered_base+=$'\n'
    done <<< "$base_records"

    sorted_base="$(printf '%s' "$filtered_base" | sed '/^$/d' | sort -t $'\t' -k7,7n -k4,4nr -k6,6)"
    selected_base=""

    if [[ -z "$project_filter" && -z "$cwd_filter" ]]; then
        selected_base="$(printf '%s\n' "$sorted_base" | take_nonempty_rows "$recent_count")"
    else
        local inspected=0 inspect_limit=10 matched=0
        if [[ "$recent_count" -gt "$inspect_limit" ]]; then
            inspect_limit="$recent_count"
        fi
        while IFS=$'\t' read -r age_seconds ago attached clients alias session activity_seconds active_ago; do
            [[ -n "$session" ]] || continue
            inspected=$((inspected + 1))
            IFS=$'\t' read -r snippet cwd_hint project_hint ui_hint < <(session_log_context "$session" "$lines" || true)
            if [[ -z "$snippet" && -z "$cwd_hint" && -z "$project_hint" ]]; then
                continue
            fi
            if [[ "$inspected" -gt "$inspect_limit" && "$matched" -eq 0 ]]; then
                break
            fi
            if [[ -n "$cwd_filter" && ( -z "$cwd_hint" || "$cwd_hint" != "$cwd_filter"* ) ]]; then
                continue
            fi
            if [[ -n "$project_filter" && "$project_hint" != "$project_filter" && "$snippet" != *"$project_filter"* ]]; then
                continue
            fi
            selected_base+=$(printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s' \
                "$age_seconds" "$ago" "$attached" "$clients" "$alias" "$session" "$activity_seconds" "$active_ago")
            selected_base+=$'\n'
            matched=$((matched + 1))
            [[ "$matched" -ge "$recent_count" ]] && break
        done <<< "$sorted_base"
    fi

    if [[ -n "$selected_base" ]]; then
        records="$(session_records "$lines" "$selected_base")"
        printf '%s' "$records" | sed '/^$/d' | sort -t $'\t' -k7,7n -k4,4nr -k6,6 | take_nonempty_rows "$recent_count"
    fi
}

current_shell_anomaly() {
    local status session
    IFS=$'\t' read -r status session < <(current_session_identity 2>/dev/null || true)
    [[ "$status" == "ancestry" && -n "$session" ]] || return 1
    printf 'GHOST\t%s\t%s\t%s\n' "$(session_alias_base "$session")" "$session" "current shell ancestry-only; not present in zmx list"
}

parse_recent_filter() {
    local raw="$1"
    if [[ "$raw" =~ ^[0-9]+$ ]]; then
        printf 'count:%s\n' "$raw"
        return 0
    fi

    if [[ "$raw" =~ ^([0-9]+)([smhd])$ ]]; then
        local value="${BASH_REMATCH[1]}"
        local unit="${BASH_REMATCH[2]}"
        local seconds="$value"
        case "$unit" in
            s) ;;
            m) seconds=$(( value * 60 )) ;;
            h) seconds=$(( value * 3600 )) ;;
            d) seconds=$(( value * 86400 )) ;;
        esac
        printf 'age:%s\n' "$seconds"
        return 0
    fi

    die "'$raw' is not a valid recent filter (use N or Ns/Nm/Nh/Nd)"
}

update_watermark() {
    local session="$1"
    line_count "$session" > "$(watermark_file "$session")"
}

ensure_bridge() {
    local session="$1"
    local bridge
    bridge="$(bridge_name "$session")"

    session_exists "$session" || die "session '$session' not found"

    # Check if bridge tmux session exists and is healthy
    if tmux has-session -t "$bridge" 2>/dev/null; then
        # Verify the pane is still running zmx
        local cmd
        cmd="$(tmux display-message -t "$bridge" -p '#{pane_current_command}' 2>/dev/null || true)"
        if [[ -n "$cmd" ]]; then
            return 0
        fi
        # Stale bridge — kill and recreate
        tmux kill-session -t "$bridge" 2>/dev/null || true
    fi

    # Create bridge — unset ZMX_SESSION so zmx attach doesn't reject
    # with CannotAttachToSessionInSession when called from inside a zmx session
    tmux new-session -d -s "$bridge" "unset ZMX_SESSION; zmx attach $session"
    sleep 1
}

session_effective_clients() {
    local session="$1"
    local clients
    clients="$(session_clients "$session" 2>/dev/null || echo 0)"
    if bridge_exists "$session" && [[ "${clients:-0}" -gt 0 ]]; then
        clients=$((clients - 1))
    fi
    echo "${clients:-0}"
}

# --- subcommands ---

cmd_list() {
    check_deps
    _build_alias_cache
    local lines=10
    local show_cwd=0
    local json=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) list_usage; return 0 ;;
            -n) [[ $# -ge 2 ]] || die "-n requires a number"; require_int "$2"; lines="$2"; shift 2 ;;
            --cwd) show_cwd=1; shift ;;
            --json) json=1; shift ;;
            *) die "unknown flag: $1" ;;
        esac
    done

    if [[ "$show_cwd" -eq 0 && "$json" -eq 0 ]]; then
        # Fast path: plain list stays cheap and delegates directly to zmx session names.
        while IFS= read -r session; do
            printf "%-20s %s\n" "${_ALIAS_CACHE[$session]:-$(session_alias_single "$session")}" "$session"
        done < <(_session_names)
        return 0
    fi

    local rows total=0
    rows="$(session_records "$lines" | sort -t $'\t' -k5,5 -k6,6)"
    [[ -n "$rows" ]] && total="$(printf '%s\n' "$rows" | sed '/^$/d' | wc -l)"

    if [[ "$json" -eq 1 ]]; then
        printf '{"count":%s,"sessions":[' "$total"
        local first=1
        while IFS=$'\t' read -r age_seconds ago attached clients alias session _activity_seconds _active_ago snippet cwd_hint project_hint ui_hint; do
            [[ -n "$session" ]] || continue
            [[ "$first" -eq 1 ]] || printf ','
            first=0
            printf '{"alias":"%s","session":"%s","project_hint":%s,"cwd_hint":%s,"ui_hint":"%s","clients":%s,"attached":%s}' \
                "$(json_escape "$alias")" \
                "$(json_escape "$session")" \
                "$(json_or_null "$(record_nullable_field "$project_hint")")" \
                "$(json_or_null "$(record_nullable_field "$cwd_hint")")" \
                "$(json_escape "$ui_hint")" \
                "$clients" \
                "$([[ "$attached" == "attached" ]] && printf 'true' || printf 'false')"
        done <<< "$rows"
        echo ']}'
        return 0
    fi

    if [[ "$show_cwd" -eq 1 ]]; then
        printf "%-18s %-42s %-14s %-8s %s\n" "ALIAS" "SESSION" "PROJECT" "UI" "CWD"
        while IFS=$'\t' read -r _age_seconds _ago _attached _clients alias session _activity_seconds _active_ago _snippet cwd_hint project_hint ui_hint; do
            [[ -n "$session" ]] || continue
            printf "%-18s %-42s %-14s %-8s %s\n" "$alias" "$session" "${project_hint:--}" "$ui_hint" "${cwd_hint:--}"
        done <<< "$rows"
    else
        printf "%-18s %-42s %-14s %s\n" "ALIAS" "SESSION" "PROJECT" "UI"
        while IFS=$'\t' read -r _age_seconds _ago _attached _clients alias session _activity_seconds _active_ago _snippet _cwd_hint project_hint ui_hint; do
            [[ -n "$session" ]] || continue
            printf "%-18s %-42s %-14s %s\n" "$alias" "$session" "${project_hint:--}" "$ui_hint"
        done <<< "$rows"
    fi
}

cmd_stale() {
    check_deps
    local older_than_hours=24
    local filter=""
    local limit=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --older-than) [[ $# -ge 2 ]] || die "--older-than requires an hour count"; require_hours "$2"; older_than_hours="$2"; shift 2 ;;
            --filter) [[ $# -ge 2 ]] || die "--filter requires a pattern"; filter="$2"; shift 2 ;;
            --limit) [[ $# -ge 2 ]] || die "--limit requires a count"; require_int "$2"; limit="$2"; shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done

    local rows="" skips=""
    rows="$(stale_candidates "$older_than_hours" "$filter" "$limit")"
    skips="$(stale_skips "$older_than_hours" "$filter")"

    if [[ -z "$rows" && -z "$skips" ]]; then
        echo "no detached zmx sessions older than ${older_than_hours}h"
        return 0
    fi

    local candidate_count skip_count
    candidate_count="$(count_rows "$rows")"
    skip_count="$(count_rows "$skips")"

    if [[ -n "$rows" ]]; then
        echo "Detached zmx sessions older than ${older_than_hours}h:"
        printf "%-4s %-18s %-42s %s\n" "AGE" "ALIAS" "SESSION" "SNIPPET"
        while IFS=$'\t' read -r age alias session snippet; do
            [[ -n "$session" ]] || continue
            printf "%-4s %-18s %-42s %s\n" "$(format_age_secs "$age")" "$alias" "$session" "$snippet"
        done <<< "$rows"
    else
        echo "No detached zmx sessions older than ${older_than_hours}h are eligible to delete."
    fi

    if [[ -n "$skips" ]]; then
        echo ""
        echo "Old zmx sessions skipped:"
        printf "%-4s %-18s %-42s %-20s %s\n" "AGE" "ALIAS" "SESSION" "WHY" "SNIPPET"
        while IFS=$'\t' read -r age alias session reason snippet; do
            [[ -n "$session" ]] || continue
            printf "%-4s %-18s %-42s %-20s %s\n" "$(format_age_secs "$age")" "$alias" "$session" "$reason" "$snippet"
        done <<< "$skips"
    fi

    echo "--- ${candidate_count} detached zmx session(s) older than ${older_than_hours}h; ${skip_count} skipped ---"
}

cmd_send() {
    check_deps
    case "${1:-}" in
        -h|--help) send_usage; return 0 ;;
    esac
    [[ $# -ge 1 ]] || die "usage: surrogate send <session> [keys...]"
    local session
    session="$(resolve_session "$1")"
    shift
    local send_detail="$*"
    local guard_reason=""
    if ! guard_reason="$(guard_self_target "$session")"; then
        audit_event "send" "$session" "deny" "$send_detail" "$guard_reason"
        die "$guard_reason"
    fi
    if ! guard_reason="$(guard_send_keys "$@")"; then
        audit_event "send" "$session" "deny" "$send_detail" "$guard_reason"
        die "$guard_reason"
    fi

    ensure_bridge "$session"
    update_watermark "$session"

    local bridge
    bridge="$(bridge_name "$session")"
    local lock
    lock="$(lock_file "$session")"

    (
        flock 9
        tmux send-keys -t "$bridge" "$@"
    ) 9>"$lock"
    audit_event "send" "$session" "allow" "$send_detail"
}

cmd_submit() {
    case "${1:-}" in
        -h|--help) submit_usage; return 0 ;;
    esac
    [[ $# -eq 1 ]] || die "usage: surrogate submit <session>"
    cmd_send "$1" Enter
}

_surrogate_prefix() {
    # Build the [SURROGATE ...] prefix based on SURROGATE_LABEL mode
    case "$SURROGATE_LABEL" in
        off) return ;;
        verbose)
            local sender_info=""
            if [[ -n "${ZMX_SESSION:-}" ]]; then
                _build_alias_cache
                local sender_alias="${_ALIAS_CACHE[$ZMX_SESSION]:-$ZMX_SESSION}"
                sender_info=" ${sender_alias}"
            fi
            local proc_name=""
            proc_name="$(ps -o comm= -p $PPID 2>/dev/null || true)"
            local cwd_short=""
            cwd_short="$(basename "$PWD")"
            printf '[SURROGATE%s %s %s PID:%s] ' "$sender_info" "${proc_name:-?}" "$cwd_short" "$$"
            ;;
        *)  # "on" (default)
            if [[ -n "${ZMX_SESSION:-}" ]]; then
                _build_alias_cache
                local sender_alias="${_ALIAS_CACHE[$ZMX_SESSION]:-$ZMX_SESSION}"
                printf '[SURROGATE %s] ' "$sender_alias"
            else
                printf '[SURROGATE] '
            fi
            ;;
    esac
}

cmd_type() {
    check_deps
    local message_mode=0
    # Extract --message and --help from any position among the args
    local positional=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) type_usage; return 0 ;;
            --message) message_mode=1; shift ;;
            *) positional+=("$1"); shift ;;
        esac
    done
    set -- "${positional[@]}"

    [[ $# -ge 2 ]] || die "usage: surrogate type [--message] <session> <text>"
    local requested_session="$1"
    local session
    session="$(resolve_session "$requested_session")"
    local original_text="$2"
    local text
    text="$(normalize_type_text "$original_text")"
    [[ -n "$text" ]] || die "type text must not be empty"
    require_seconds "$SURROGATE_TYPE_ENTER_DELAY_SECS"
    require_seconds "$SURROGATE_TYPE_POSTCHECK_SECS"

    local history ui_hint
    history="$(session_recent_history "$session" 10)"
    ui_hint="$(ui_hint_from_history "$history")"

    local guard_reason=""
    if ! guard_reason="$(guard_self_target "$session")"; then
        audit_event "type" "$session" "deny" "$original_text" "$guard_reason"
        die "$guard_reason"
    fi
    if [[ "$message_mode" -eq 1 && "$ui_hint" != "agent" ]]; then
        guard_reason="--message requires an agent-like target; current ui_hint is '$ui_hint'"
        audit_event "type" "$session" "deny" "$original_text" "$guard_reason"
        die "$guard_reason"
    fi
    if [[ "$message_mode" -eq 0 ]] && ! guard_reason="$(scan_with_dcg "$text")"; then
        audit_event "type" "$session" "deny" "$original_text" "$guard_reason"
        die "$guard_reason"
    fi

    local start_lines=0
    start_lines="$(line_count "$session")"

    # Prepend surrogate label for agent-like contexts and explicit message sends.
    local prefix
    prefix=""
    if [[ "$message_mode" -eq 1 || "$ui_hint" != "shell" ]]; then
        prefix="$(_surrogate_prefix)"
    fi
    if [[ -n "$prefix" ]]; then
        text="${prefix}${text}"
    fi

    ensure_bridge "$session"
    update_watermark "$session"

    local bridge
    bridge="$(bridge_name "$session")"
    local lock
    lock="$(lock_file "$session")"

    if ! (
        flock 9
        tmux send-keys -t "$bridge" -l "$text"
        sleep "$SURROGATE_TYPE_ENTER_DELAY_SECS"
        tmux send-keys -t "$bridge" Enter
    ) 9>"$lock"; then
        die "type delivery failed; if the text is already staged, run: surrogate submit $requested_session"
    fi
    audit_event "type" "$session" "allow" "$text"

    if [[ "$ui_hint" != "agent" ]]; then
        sleep "$SURROGATE_TYPE_POSTCHECK_SECS"
        local new_output shell_reason
        new_output="$(zmx history "$session" 2>/dev/null | tail -n +"$((start_lines + 1))")"
        shell_reason="$(shell_error_reason "$new_output" || true)"
        if [[ -n "$shell_reason" ]]; then
            warn "target shell immediately reported: $shell_reason"
            warn "inspect with: surrogate read $requested_session -n 40"
        fi
    fi
}

cmd_read() {
    check_deps
    [[ $# -ge 1 ]] || die "usage: surrogate read <session> [-n LINES]"
    local session
    session="$(resolve_session "$1")"
    shift

    local lines=20
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n) [[ $# -ge 2 ]] || die "-n requires a number"; require_int "$2"; lines="$2"; shift 2 ;;
            *)  die "unknown flag: $1" ;;
        esac
    done

    zmx history "$session" | tail -n "$lines"
}

cmd_wait() {
    check_deps
    [[ $# -ge 2 ]] || die "usage: surrogate wait <session> <pattern> [-t TIMEOUT]"
    local session
    session="$(resolve_session "$1")"
    local pattern="$2"
    shift 2

    local timeout=30
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -t) [[ $# -ge 2 ]] || die "-t requires seconds"; require_int "$2"; timeout="$2"; shift 2 ;;
            *)  die "unknown flag: $1" ;;
        esac
    done

    local wm_file
    wm_file="$(watermark_file "$session")"
    local watermark=0
    if [[ -f "$wm_file" ]]; then
        watermark="$(cat "$wm_file")"
    fi

    local elapsed=0
    while [[ $elapsed -lt $timeout ]]; do
        if zmx history "$session" | tail -n +"$((watermark + 1))" | grep -qE "$pattern"; then
            return 0
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done

    die "timeout after ${timeout}s waiting for pattern: $pattern"
}

cmd_find() {
    check_deps
    _build_alias_cache
    [[ $# -ge 1 ]] || die "usage: surrogate find <query> [-n LINES] [-C CONTEXT]"
    local query="$1"
    [[ -z "$query" ]] && die "query must not be empty"
    shift

    local lines=200
    local context=1
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n) [[ $# -ge 2 ]] || die "-n requires a number"; require_int "$2"; lines="$2"; shift 2 ;;
            -C) [[ $# -ge 2 ]] || die "-C requires a number"; require_int "$2"; context="$2"; shift 2 ;;
            *)  die "unknown flag: $1" ;;
        esac
    done

    local found=0
    while IFS= read -r session; do
        local output
        output="$(zmx history "$session" 2>/dev/null | tail -n "$lines" | _search -i -C "$context" -- "$query" 2>/dev/null || true)"
        if [[ -n "$output" ]]; then
            local count
            count="$(echo "$output" | _search -c -i -- "$query" 2>/dev/null || echo 0)"
            echo "═══ ${_ALIAS_CACHE[$session]}  $session ($count matches) ═══"
            echo "$output"
            echo ""
            found=$((found + 1))
        fi
    done < <(_session_names)

    if [[ $found -eq 0 ]]; then
        echo "no matches for '$query' across $(zmx list 2>/dev/null | wc -l) sessions"
    else
        echo "--- $found session(s) matched ---"
    fi
}

cmd_who() {
    check_deps

    local lines=10
    local json=0
    local recent_count=""
    local recent_age_max=""
    local recent_explicit=0
    local project_filter=""
    local cwd_filter=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) who_usage; return 0 ;;
            -n) [[ $# -ge 2 ]] || die "-n requires a number"; require_int "$2"; lines="$2"; shift 2 ;;
            --json) json=1; shift ;;
            --project) [[ $# -ge 2 ]] || die "--project requires a name"; project_filter="$2"; shift 2 ;;
            --cwd) [[ $# -ge 2 ]] || die "--cwd requires a path"; cwd_filter="$2"; shift 2 ;;
            --recent)
                [[ $# -ge 2 ]] || die "--recent requires a value"
                local recent_mode
                recent_mode="$(parse_recent_filter "$2")"
                recent_explicit=1
                case "$recent_mode" in
                    count:*) recent_count="${recent_mode#count:}" ;;
                    age:*)
                        recent_age_max="${recent_mode#age:}"
                        recent_count=""
                        ;;
                esac
                shift 2
                ;;
            *)  die "unknown flag: $1" ;;
        esac
    done

    if [[ "$recent_explicit" -eq 0 ]]; then
        recent_count=20
    fi

    local base_records selected_base records filtered=""
    base_records="$(session_base_records | sort -t $'\t' -k1,1n -k6,6)"
    if [[ -n "$recent_age_max" ]]; then
        base_records="$(
            while IFS=$'\t' read -r age_seconds ago attached clients alias session; do
                [[ -n "$session" ]] || continue
                [[ "$age_seconds" -le "$recent_age_max" ]] || continue
                printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
                    "$age_seconds" "$ago" "$attached" "$clients" "$alias" "$session"
            done <<< "$base_records"
        )"
    fi

    selected_base="$base_records"
    if [[ -n "$recent_count" && -z "$project_filter" && -z "$cwd_filter" ]]; then
        selected_base="$(printf '%s\n' "$selected_base" | take_nonempty_rows "$recent_count")"
    fi

    records="$(session_records "$lines" "$selected_base")"
    while IFS=$'\t' read -r age_seconds ago attached clients alias session _activity_seconds _active_ago snippet cwd_hint project_hint ui_hint; do
        [[ -n "$session" ]] || continue
        if [[ -n "$cwd_filter" && ( -z "$cwd_hint" || "$cwd_hint" != "$cwd_filter"* ) ]]; then
            continue
        fi

        if [[ -n "$project_filter" && "$project_hint" != "$project_filter" ]]; then
            continue
        fi

        filtered+=$(printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s' \
            "$age_seconds" "$ago" "$attached" "$clients" "$alias" \
            "$session" "$snippet" "$cwd_hint" "$project_hint" "$ui_hint")
        filtered+=$'\n'
    done <<< "$records"

    local sorted
    sorted="$(printf '%s' "$filtered" | sed '/^$/d')"
    if [[ "$recent_explicit" -eq 1 && -n "$recent_count" ]]; then
        sorted="$(printf '%s\n' "$sorted" | take_nonempty_rows "$recent_count")"
    fi

    local total=0
    [[ -n "$sorted" ]] && total="$(printf '%s\n' "$sorted" | sed '/^$/d' | wc -l)"

    if [[ "$json" -eq 1 ]]; then
        printf '{"count":%s,"recent_first":true,"sessions":[' "$total"
        local first=1
        while IFS=$'\t' read -r age_seconds ago attached clients alias session snippet cwd_hint project_hint ui_hint; do
            [[ -z "$session" ]] && continue
            [[ "$first" -eq 1 ]] || printf ','
            first=0
            printf '{"alias":"%s","session":"%s","clients":%s,"attached":%s,"age":"%s","age_seconds":%s,"snippet":"%s","cwd_hint":%s,"project_hint":%s,"ui_hint":"%s"}' \
                "$(json_escape "$alias")" \
                "$(json_escape "$session")" \
                "$clients" \
                "$([[ "$attached" == "attached" ]] && printf 'true' || printf 'false')" \
                "$(json_escape "$ago")" \
                "$age_seconds" \
                "$(json_escape "$snippet")" \
                "$(json_or_null "$(record_nullable_field "$cwd_hint")")" \
                "$(json_or_null "$(record_nullable_field "$project_hint")")" \
                "$(json_escape "$ui_hint")"
        done <<< "$sorted"
        echo ']}'
        return 0
    fi

    while IFS=$'\t' read -r _age_seconds ago attached _clients alias session snippet _cwd_hint project_hint ui_hint; do
        [[ -z "$session" ]] && continue
        local attached_mark=""
        [[ "$attached" == "attached" ]] && attached_mark="*"
        printf "%-4s %-8s %-18s %-42s %-12s %s\n" "${ago}${attached_mark}" "$ui_hint" "$alias" "$session" "${project_hint:--}" "$snippet"
    done <<< "$sorted"

    if [[ "$recent_explicit" -eq 0 && -z "$project_filter" && -z "$cwd_filter" ]]; then
        echo "── $total sessions shown (* = attached, newest first; default window) ──"
    else
        echo "── $total sessions (* = attached, newest first) ──"
    fi
}

cmd_active() {
    check_deps
    _build_alias_cache

    local mode="attached"
    local lines=10
    local json=0
    local recent_count=20
    local recent_age_max=""
    local project_filter=""
    local cwd_filter=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) active_usage; return 0 ;;
            --all) mode="all"; shift ;;
            -n) [[ $# -ge 2 ]] || die "-n requires a number"; require_int "$2"; lines="$2"; shift 2 ;;
            --json) json=1; shift ;;
            --project) [[ $# -ge 2 ]] || die "--project requires a name"; project_filter="$2"; shift 2 ;;
            --cwd) [[ $# -ge 2 ]] || die "--cwd requires a path"; cwd_filter="$2"; shift 2 ;;
            --recent)
                [[ $# -ge 2 ]] || die "--recent requires a value"
                local recent_mode
                recent_mode="$(parse_recent_filter "$2")"
                case "$recent_mode" in
                    count:*) recent_count="${recent_mode#count:}" ;;
                    age:*) recent_age_max="${recent_mode#age:}" ;;
                esac
                shift 2
                ;;
            *) die "unknown flag: $1" ;;
        esac
    done

    local sorted total=0
    sorted="$(activity_ranked_records "$mode" "$lines" "$recent_count" "$recent_age_max" "$project_filter" "$cwd_filter")"
    [[ -n "$sorted" ]] && total="$(printf '%s
' "$sorted" | sed '/^$/d' | wc -l)"

    if [[ "$json" -eq 1 ]]; then
        printf '{"count":%s,"activity_ranked":true,"sessions":[' "$total"
        local first=1
        while IFS=$'	' read -r age_seconds ago attached clients alias session activity_seconds active_ago snippet cwd_hint project_hint ui_hint; do
            [[ -n "$session" ]] || continue
            [[ "$first" -eq 1 ]] || printf ','
            first=0
            printf '{"alias":"%s","session":"%s","clients":%s,"attached":%s,"last_active":"%s","last_active_seconds":%s,"age":"%s","age_seconds":%s,"snippet":"%s","cwd_hint":%s,"project_hint":%s,"ui_hint":"%s"}' \
                "$(json_escape "$alias")" \
                "$(json_escape "$session")" \
                "$clients" \
                "$([[ "$attached" == "attached" ]] && printf 'true' || printf 'false')" \
                "$(json_escape "$active_ago")" \
                "$activity_seconds" \
                "$(json_escape "$ago")" \
                "$age_seconds" \
                "$(json_escape "$snippet")" \
                "$(json_or_null "$(record_nullable_field "$cwd_hint")")" \
                "$(json_or_null "$(record_nullable_field "$project_hint")")" \
                "$(json_escape "$ui_hint")"
        done <<< "$sorted"
        echo ']}'
        return 0
    fi

    printf "%-6s %-4s %-8s %-18s %-42s %-12s %s
" "ACTIVE" "AGE" "UI" "ALIAS" "SESSION" "PROJECT" "SNIPPET"
    while IFS=$'	' read -r _age_seconds ago attached _clients alias session _activity_seconds active_ago snippet _cwd_hint project_hint ui_hint; do
        [[ -n "$session" ]] || continue
        local attached_mark=""
        [[ "$attached" == "attached" ]] && attached_mark="*"
        printf "%-6s %-4s %-8s %-18s %-42s %-12s %s
" "${active_ago}${attached_mark}" "$ago" "$ui_hint" "$alias" "$session" "${project_hint:--}" "$snippet"
    done <<< "$sorted"

    echo "── $total sessions (recent activity first; * = attached) ──"
}

cmd_live() {
    check_deps
    _build_alias_cache

    local lines=10
    local json=0
    local show_all=0
    local recent_count=15
    local recent_age_max=""
    local project_filter=""
    local cwd_filter=""
    local here=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) live_usage; return 0 ;;
            -n) [[ $# -ge 2 ]] || die "-n requires a number"; require_int "$2"; lines="$2"; shift 2 ;;
            --all) show_all=1; shift ;;
            --json) json=1; shift ;;
            --project) [[ $# -ge 2 ]] || die "--project requires a name"; project_filter="$2"; shift 2 ;;
            --cwd) [[ $# -ge 2 ]] || die "--cwd requires a path"; cwd_filter="$2"; shift 2 ;;
            --here) here=1; shift ;;
            --recent)
                [[ $# -ge 2 ]] || die "--recent requires a value"
                local recent_mode
                recent_mode="$(parse_recent_filter "$2")"
                case "$recent_mode" in
                    count:*) recent_count="${recent_mode#count:}" ;;
                    age:*) recent_age_max="${recent_mode#age:}" ;;
                esac
                shift 2
                ;;
            *) die "unknown flag: $1" ;;
        esac
    done

    if [[ "$here" -eq 1 ]]; then
        [[ -z "$project_filter" ]] || die "cannot combine --here with --project"
        project_filter="$(current_repo_name)"
    fi

    local sorted total=0 anomaly=""
    sorted="$(activity_ranked_records "live" "$lines" "$recent_count" "$recent_age_max" "$project_filter" "$cwd_filter")"
    [[ -n "$sorted" ]] && total="$(printf '%s\n' "$sorted" | sed '/^$/d' | wc -l)"
    anomaly="$(current_shell_anomaly || true)"

    local display_rows="$sorted"
    local display_total="$total"
    local hidden_low_signal=0
    local signal_filtered=0
    if [[ "$show_all" -eq 0 && -z "$project_filter" && -z "$cwd_filter" && -n "$sorted" ]]; then
        local focused_rows=""
        while IFS=$'\t' read -r age_seconds ago attached clients alias session activity_seconds active_ago snippet cwd_hint project_hint ui_hint; do
            [[ -n "$session" ]] || continue
            if [[ "$project_hint" != "-" || "$cwd_hint" != "-" || "$ui_hint" == "agent" ]]; then
                focused_rows+=$(printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s' \
                    "$age_seconds" "$ago" "$attached" "$clients" "$alias" "$session" \
                    "$activity_seconds" "$active_ago" "$snippet" "$cwd_hint" "$project_hint" "$ui_hint")
                focused_rows+=$'\n'
            else
                hidden_low_signal=$((hidden_low_signal + 1))
            fi
        done <<< "$sorted"

        if [[ -n "$focused_rows" ]]; then
            display_rows="$(printf '%s' "$focused_rows" | sed '/^$/d')"
            display_total="$(count_rows "$display_rows")"
            signal_filtered=1
        else
            hidden_low_signal=0
        fi
    fi

    if [[ "$json" -eq 1 ]]; then
        printf '{"count":%s,"total_live_count":%s,"messageable_only":true' "$display_total" "$total"
        printf ',"high_signal_only":%s,"hidden_low_signal_count":%s' \
            "$([[ "$signal_filtered" -eq 1 ]] && printf 'true' || printf 'false')" \
            "$hidden_low_signal"
        if [[ -n "$anomaly" ]]; then
            local anomaly_state anomaly_alias anomaly_session anomaly_note
            IFS=$'\t' read -r anomaly_state anomaly_alias anomaly_session anomaly_note <<< "$anomaly"
            printf ',"current_shell":{"state":"%s","alias":"%s","session":"%s","note":"%s"}' \
                "$(json_escape "$anomaly_state")" \
                "$(json_escape "$anomaly_alias")" \
                "$(json_escape "$anomaly_session")" \
                "$(json_escape "$anomaly_note")"
        else
            printf ',"current_shell":null'
        fi
        printf ',"sessions":['
        local first=1
        while IFS=$'\t' read -r age_seconds ago attached clients alias session activity_seconds active_ago snippet cwd_hint project_hint ui_hint; do
            [[ -n "$session" ]] || continue
            [[ "$first" -eq 1 ]] || printf ','
            first=0
            printf '{"state":"live","alias":"%s","session":"%s","clients":%s,"attached":%s,"last_active":"%s","last_active_seconds":%s,"age":"%s","age_seconds":%s,"snippet":"%s","cwd_hint":%s,"project_hint":%s,"ui_hint":"%s"}' \
                "$(json_escape "$alias")" \
                "$(json_escape "$session")" \
                "$clients" \
                "$([[ "$attached" == "attached" ]] && printf 'true' || printf 'false')" \
                "$(json_escape "$active_ago")" \
                "$activity_seconds" \
                "$(json_escape "$ago")" \
                "$age_seconds" \
                "$(json_escape "$snippet")" \
                "$(json_or_null "$(record_nullable_field "$cwd_hint")")" \
                "$(json_or_null "$(record_nullable_field "$project_hint")")" \
                "$(json_escape "$ui_hint")"
        done <<< "$display_rows"
        echo ']}'
        return 0
    fi

    if [[ -n "$display_rows" ]]; then
        printf "%-6s %-6s %-4s %-18s %-12s %-42s %s\n" "STATE" "ACTIVE" "AGE" "ALIAS" "PROJECT" "SESSION" "SNIPPET"
        while IFS=$'\t' read -r _age_seconds ago _attached _clients alias session _activity_seconds active_ago snippet _cwd_hint project_hint _ui_hint; do
            [[ -n "$session" ]] || continue
            printf "%-6s %-6s %-4s %-18s %-12s %-42s %s\n" "LIVE" "$active_ago" "$ago" "$alias" "${project_hint:--}" "$session" "$snippet"
        done <<< "$display_rows"
        if [[ "$signal_filtered" -eq 1 ]]; then
            echo "── $display_total likely-actionable live session(s); $hidden_low_signal low-signal live session(s) hidden ──"
        else
            echo "── $display_total live session(s), recent activity first ──"
        fi
    else
        echo "no live messageable sessions matched"
    fi

    if [[ -n "$anomaly" ]]; then
        echo ""
        echo "Current shell anomaly:"
        printf "%-6s %-18s %-42s %s\n" "STATE" "ALIAS" "SESSION" "NOTE"
        local anomaly_state anomaly_alias anomaly_session anomaly_note
        IFS=$'\t' read -r anomaly_state anomaly_alias anomaly_session anomaly_note <<< "$anomaly"
        printf "%-6s %-18s %-42s %s\n" "$anomaly_state" "$anomaly_alias" "$anomaly_session" "$anomaly_note"
    fi

    if [[ "$signal_filtered" -eq 1 ]]; then
        echo "Hidden by design: old detached sessions and low-signal live lanes. Review with: surrogate live --all --recent $recent_count"
    else
        echo "Hidden by design: old detached sessions. Review with: surrogate stale --older-than 72"
    fi
}

cmd_brief() {
    check_deps

    local recent_arg=""
    local project_filter=""
    local cwd_filter=""
    local include_all=0
    local show_config=0
    local -a explicit_sessions=()
    local -a brief_args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                brief_usage
                return 0
                ;;
            --recent)
                [[ $# -ge 2 ]] || die "--recent requires a value"
                parse_recent_filter "$2" >/dev/null
                recent_arg="$2"
                shift 2
                ;;
            --project)
                [[ $# -ge 2 ]] || die "--project requires a name"
                project_filter="$2"
                shift 2
                ;;
            --cwd)
                [[ $# -ge 2 ]] || die "--cwd requires a path"
                cwd_filter="$2"
                shift 2
                ;;
            --all)
                include_all=1
                shift
                ;;
            --config|--model|--openrouter-model|--llm-model|--provider|--inference-provider|--temperature|--max-completion-tokens|--api-url|-n)
                [[ $# -ge 2 ]] || die "$1 requires a value"
                brief_args+=("$1" "$2")
                shift 2
                ;;
            --no-config|--no-fallbacks)
                brief_args+=("$1")
                shift
                ;;
            --show-config)
                show_config=1
                brief_args+=("$1")
                shift
                ;;
            --)
                shift
                while [[ $# -gt 0 ]]; do
                    explicit_sessions+=("$1")
                    shift
                done
                ;;
            -*)
                die "unknown flag: $1"
                ;;
            *)
                if [[ -z "$recent_arg" && "${#explicit_sessions[@]}" -eq 0 && "$1" =~ ^[0-9]+([smhd])?$ ]]; then
                    parse_recent_filter "$1" >/dev/null
                    recent_arg="$1"
                else
                    explicit_sessions+=("$1")
                fi
                shift
                ;;
        esac
    done

    local brief_bin
    brief_bin="$(brief_cmd_path)"

    if [[ "${#explicit_sessions[@]}" -gt 0 ]]; then
        "$brief_bin" "${brief_args[@]}" "${explicit_sessions[@]}"
        return 0
    fi

    if [[ "$show_config" -eq 1 ]]; then
        "$brief_bin" "${brief_args[@]}"
        return 0
    fi

    local -a selector_args=("live" "--json")
    [[ "$include_all" -eq 1 ]] && selector_args+=("--all")
    [[ -n "$recent_arg" ]] && selector_args+=("--recent" "$recent_arg")
    [[ -n "$project_filter" ]] && selector_args+=("--project" "$project_filter")
    [[ -n "$cwd_filter" ]] && selector_args+=("--cwd" "$cwd_filter")

    local selected
    selected="$("$0" "${selector_args[@]}" | python3 -c 'import json, sys
obj = json.load(sys.stdin)
for item in obj.get("sessions", []):
    session = item.get("session")
    if session:
        print(session)
')"

    [[ -n "$selected" ]] || die "no sessions matched the brief selection"

    local -a selected_sessions=()
    while IFS= read -r session; do
        [[ -n "$session" ]] || continue
        selected_sessions+=("$session")
    done <<< "$selected"

    "$brief_bin" "${brief_args[@]}" "${selected_sessions[@]}"
}

cmd_peek() {
    check_deps
    _build_alias_cache

    local lines=5
    local filter=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n) [[ $# -ge 2 ]] || die "-n requires a number"; require_int "$2"; lines="$2"; shift 2 ;;
            --filter) [[ $# -ge 2 ]] || die "--filter requires a pattern"; filter="$2"; shift 2 ;;
            *)  die "unknown flag: $1" ;;
        esac
    done

    local count=0
    while IFS= read -r session; do
        local output
        output="$(zmx history "$session" 2>/dev/null | tail -n "$lines" | sed '/^[[:space:]]*$/d')"
        [[ -z "$output" ]] && continue

        # Apply filter if given (matches against output content AND alias)
        if [[ -n "$filter" ]]; then
            if ! echo "$output" | _search -qi -- "$filter" 2>/dev/null; then
                if ! echo "${_ALIAS_CACHE[$session]} $session" | _search -qi -- "$filter" 2>/dev/null; then
                    continue
                fi
            fi
        fi

        echo "─── ${_ALIAS_CACHE[$session]}  $session ───"
        echo "$output"
        echo ""
        count=$((count + 1))
    done < <(_session_names)

    echo "--- peeked $count session(s) ---"
}

cmd_alias() {
    check_deps
    [[ $# -ge 1 ]] || die "usage: surrogate alias <session>"
    local session
    session="$(resolve_session "$1")"
    _build_alias_cache
    echo "${_ALIAS_CACHE[$session]}"
}

whoami_usage() {
    cat <<'EOF'
usage: surrogate whoami

Show the current zmx session name and its surrogate alias.
EOF
}

cmd_whoami() {
    check_deps
    case "${1:-}" in
        -h|--help)
            whoami_usage
            return 0
            ;;
    esac
    [[ $# -eq 0 ]] || die "usage: surrogate whoami"

    local status session alias
    if ! IFS=$'\t' read -r status session < <(current_session_identity 2>/dev/null || true); then
        die "not inside a zmx session (ZMX_SESSION not set)"
    fi
    if [[ -z "$status" || -z "$session" ]]; then
        die "not inside a zmx session (ZMX_SESSION not set)"
    fi

    case "$status" in
        live)
            _build_alias_cache
            alias="${_ALIAS_CACHE[$session]:-$(session_alias "$session")}"
            echo "$alias  $session"
            ;;
        ancestry)
            alias="$(session_alias_base "$session")"
            echo "$alias  $session  (ancestry-only; not present in zmx list, not messageable via surrogate)"
            ;;
        stale-env)
            die "current ZMX_SESSION '$session' is not present in zmx list (stale or leaked environment)"
            ;;
        *)
            die "not inside a zmx session (ZMX_SESSION not set)"
            ;;
    esac
}

cmd_rename() {
    check_deps
    [[ $# -ge 2 ]] || die "usage: surrogate rename <session> <new-alias>"
    local session
    session="$(resolve_session "$1")"
    local new_alias="$2"

    # Check the new alias doesn't collide with an existing session name
    if session_exists "$new_alias"; then
        die "'$new_alias' is a zmx session name, not an alias — use a different name"
    fi

    _build_alias_cache
    set +u
    local old_alias="${_ALIAS_CACHE[$session]:-$session}"
    set -u

    # Check the new alias isn't already taken by another session
    if [[ -n "${_ALIAS_REVERSE[$new_alias]:-}" ]]; then
        local other="${_ALIAS_REVERSE[$new_alias]}"
        if [[ "$other" != "$session" ]]; then
            die "alias '$new_alias' is already used by $other"
        fi
    fi

    # Write custom alias to file (append or update)
    if [[ -f "$ALIAS_FILE" ]] && grep -q "^${session}=" "$ALIAS_FILE" 2>/dev/null; then
        sed -i "s|^${session}=.*|${session}=${new_alias}|" "$ALIAS_FILE"
    else
        echo "${session}=${new_alias}" >> "$ALIAS_FILE"
    fi

    echo "renamed: $old_alias -> $new_alias  ($session)"
}

deprecated_command_warning() {
    local old_cmd="$1"
    local new_cmd="$2"
    local note="${3:-}"
    if [[ -n "$note" ]]; then
        warn "'$old_cmd' is deprecated. Use '$new_cmd' instead. $note"
    else
        warn "'$old_cmd' is deprecated. Use '$new_cmd' instead."
    fi
}

cmd_prune_sessions() {
    check_deps
    local mode="explicit"
    local older_than_hours=24
    local filter=""
    local limit=0
    local dry_run=0
    local assume_yes=0
    local auto_preview=0
    local explicit_invalid=0
    local -a requested=()
    local -a targets=()
    local rows=""
    local skipped=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) prune_sessions_usage; return 0 ;;
            --stale) mode="stale"; shift ;;
            --older-than) [[ $# -ge 2 ]] || die "--older-than requires an hour count"; require_hours "$2"; older_than_hours="$2"; shift 2 ;;
            --filter) [[ $# -ge 2 ]] || die "--filter requires a pattern"; filter="$2"; shift 2 ;;
            --limit) [[ $# -ge 2 ]] || die "--limit requires a count"; require_int "$2"; limit="$2"; shift 2 ;;
            --dry-run) dry_run=1; shift ;;
            --yes) assume_yes=1; shift ;;
            -*) die "unknown flag: $1" ;;
            *) requested+=("$1"); shift ;;
        esac
    done

    if [[ "$mode" == "stale" && "${#requested[@]}" -gt 0 ]]; then
        die "cannot mix explicit sessions with --stale"
    fi
    if [[ "$mode" == "explicit" && "${#requested[@]}" -eq 0 ]]; then
        die "usage: surrogate prune-sessions <session>... [--dry-run] | surrogate prune-sessions --stale [--older-than HOURS] [--filter PATTERN] [--limit N] [--dry-run|--yes]"
    fi
    if [[ "$mode" == "explicit" && ( -n "$filter" || "$limit" -gt 0 || "$older_than_hours" -ne 24 ) ]]; then
        die "--older-than, --filter, and --limit require --stale"
    fi

    if [[ "$mode" == "stale" ]]; then
        rows="$(stale_candidates "$older_than_hours" "$filter" "$limit")"
        skipped="$(stale_skips "$older_than_hours" "$filter")"
        while IFS=$'\t' read -r _age _alias session _snippet; do
            [[ -n "$session" ]] || continue
            targets+=("$session")
        done <<< "$rows"
        if [[ "$dry_run" -eq 0 && "$assume_yes" -eq 0 ]]; then
            auto_preview=1
            dry_run=1
        fi
    else
        local input session guard_reason
        for input in "${requested[@]}"; do
            session="$(resolve_session "$input")"
            if ! guard_reason="$(ensure_cullable_session "$session")"; then
                skipped+="$(session_review_row "$session" | awk -F '\t' -v reason="$guard_reason" '{printf "%s\t%s\t%s\t%s\t%s\n", $1, $2, $3, reason, $4}')"
                skipped+=$'\n'
                explicit_invalid=1
                continue
            fi
            targets+=("$session")
            rows+="$(session_review_row "$session")"
            rows+=$'\n'
        done
        rows="$(printf '%s' "$rows" | sed '/^$/d' | sort -rn -k1,1)"
        skipped="$(printf '%s' "$skipped" | sed '/^$/d' | sort -rn -k1,1)"
    fi

    if [[ -z "$rows" && -z "$skipped" ]]; then
        if [[ "$mode" == "stale" ]]; then
            echo "no detached zmx sessions to prune"
            return 0
        fi
        echo "no eligible zmx sessions to prune"
        return 1
    fi

    local candidate_count skip_count bridge_count
    candidate_count="$(count_rows "$rows")"
    skip_count="$(count_rows "$skipped")"
    bridge_count="$(bridge_count_for_rows "$rows")"

    if [[ -n "$rows" ]]; then
        if [[ "$dry_run" -eq 1 ]]; then
            echo "Would delete these zmx sessions:"
        else
            echo "Deleting these zmx sessions:"
        fi
        printf "%-4s %-18s %-42s %-6s %s\n" "AGE" "ALIAS" "SESSION" "BRIDGE" "SNIPPET"
        local age alias session snippet bridge_label
        while IFS=$'\t' read -r age alias session snippet; do
            [[ -n "$session" ]] || continue
            if bridge_exists "$session"; then
                bridge_label="yes"
            else
                bridge_label="no"
            fi
            printf "%-4s %-18s %-42s %-6s %s\n" "$(format_age_secs "$age")" "$alias" "$session" "$bridge_label" "$snippet"
        done <<< "$rows"
    else
        echo "No eligible zmx sessions would be deleted."
    fi

    if [[ -n "$skipped" ]]; then
        echo ""
        if [[ "$mode" == "stale" ]]; then
            echo "Skipped old zmx sessions:"
        else
            echo "Skipped requested zmx sessions:"
        fi
        printf "%-4s %-18s %-42s %-24s %s\n" "AGE" "ALIAS" "SESSION" "WHY" "SNIPPET"
        local age alias session reason snippet
        while IFS=$'\t' read -r age alias session reason snippet; do
            [[ -n "$session" ]] || continue
            printf "%-4s %-18s %-42s %-24s %s\n" "$(format_age_secs "$age")" "$alias" "$session" "$reason" "$snippet"
        done <<< "$skipped"
    fi

    echo ""
    if [[ "$dry_run" -eq 1 ]]; then
        echo "would delete ${candidate_count} zmx session(s)"
        echo "would remove ${bridge_count} surrogate tmux bridge(s)"
        if [[ "$mode" == "stale" && "$auto_preview" -eq 1 ]]; then
            echo "Preview only. Re-run with --yes to delete these zmx sessions and remove their surrogate tmux bridges."
        fi
        [[ "$explicit_invalid" -eq 0 || "$candidate_count" -gt 0 ]] && return 0
        return 1
    fi

    local deleted=0 removed_bridges=0
    local session alias age_label had_bridge
    _build_alias_cache
    for session in "${targets[@]}"; do
        [[ -n "$session" ]] || continue
        alias="${_ALIAS_CACHE[$session]:-$(session_alias "$session")}"
        age_label="$(format_age_secs "$(session_age_secs "$session" 2>/dev/null || echo 0)")"
        had_bridge=0
        if bridge_exists "$session"; then
            had_bridge=1
        fi
        prune_session "$session"
        deleted=$((deleted + 1))
        echo "deleted zmx session: $alias  $session  age=$age_label"
        if [[ "$had_bridge" -eq 1 ]]; then
            removed_bridges=$((removed_bridges + 1))
            echo "removed surrogate tmux bridge: $(bridge_name "$session")"
        fi
    done

    echo ""
    echo "deleted ${deleted} zmx session(s)"
    echo "removed ${removed_bridges} surrogate tmux bridge(s)"
}

cmd_cull() {
    deprecated_command_warning "surrogate cull" "surrogate prune-sessions" "Batch stale pruning now previews by default; add --yes to execute."
    cmd_prune_sessions "$@"
}

cmd_sweep() {
    check_deps
    case "${1:-}" in
        -h|--help)
            sweep_usage
            return 0
            ;;
    esac
    cmd_prune_sessions --stale "$@"
}

cmd_bridge() {
    check_deps
    [[ $# -ge 1 ]] || die "usage: surrogate bridge <session>"
    local session
    session="$(resolve_session "$1")"
    ensure_bridge "$session"
    echo "bridge ready: $(bridge_name "$session")"
}

cmd_prune_bridges() {
    check_deps
    local mode="--dead"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) prune_bridges_usage; return 0 ;;
            --dead) mode="--dead"; shift ;;
            --all) mode="--all"; shift ;;
            *) die "unknown flag: $1 (use --all or --dead)" ;;
        esac
    done

    local sessions candidates removed=0
    sessions="$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep "^${BRIDGE_PREFIX}" || true)"
    if [[ -z "$sessions" ]]; then
        echo "no surrogate tmux bridges to prune"
        return 0
    fi

    candidates=""
    while IFS= read -r s; do
        [[ -n "$s" ]] || continue
        local zmx_name="${s#"$BRIDGE_PREFIX"}"
        if [[ "$mode" == "--all" ]]; then
            candidates+="$s"
            candidates+=$'\n'
        elif ! session_exists "$zmx_name"; then
            candidates+="$s"
            candidates+=$'\n'
        fi
    done <<< "$sessions"

    if [[ -z "$candidates" ]]; then
        echo "no surrogate tmux bridges to prune"
        return 0
    fi

    while IFS= read -r s; do
        [[ -n "$s" ]] || continue
        local zmx_name="${s#"$BRIDGE_PREFIX"}"
        if tmux kill-session -t "$s" 2>/dev/null; then
            removed=$((removed + 1))
            if [[ "$mode" == "--all" ]]; then
                echo "removed surrogate tmux bridge: $s"
            else
                echo "removed surrogate tmux bridge: $s (zmx session '$zmx_name' was already gone)"
            fi
        fi
    done <<< "$candidates"

    echo "removed ${removed} surrogate tmux bridge(s)"
}

cmd_cleanup() {
    deprecated_command_warning "surrogate cleanup" "surrogate prune-bridges" "This command only removes surrogate tmux bridges, not zmx sessions."
    cmd_prune_bridges "$@"
}

cmd_status() {
    check_deps
    local sessions
    sessions="$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep "^${BRIDGE_PREFIX}" || true)"

    if [[ -z "$sessions" ]]; then
        echo "no active bridges"
        return
    fi

    printf "%-50s %s\n" "BRIDGE" "STATUS"
    while IFS= read -r s; do
        local zmx_name="${s#"$BRIDGE_PREFIX"}"
        local status
        if session_exists "$zmx_name"; then
            status="ok"
        else
            status="DEAD (zmx session gone)"
        fi
        printf "%-50s %s\n" "$s" "$status"
    done <<< "$sessions"
}

# --- main ---

[[ $# -eq 0 ]] && usage

case "${1}" in
    list)    shift; cmd_list "$@" ;;
    stale)   shift; cmd_stale "$@" ;;
    sweep)   shift; cmd_sweep "$@" ;;
    send)    shift; cmd_send "$@" ;;
    submit)  shift; cmd_submit "$@" ;;
    type)    shift; cmd_type "$@" ;;
    read)    shift; cmd_read "$@" ;;
    wait)    shift; cmd_wait "$@" ;;
    find)    shift; cmd_find "$@" ;;
    who)     shift; cmd_who "$@" ;;
    active)  shift; cmd_active "$@" ;;
    live)    shift; cmd_live "$@" ;;
    brief)   shift; cmd_brief "$@" ;;
    peek)    shift; cmd_peek "$@" ;;
    alias)   shift; cmd_alias "$@" ;;
    whoami)  shift; cmd_whoami "$@" ;;
    rename)  shift; cmd_rename "$@" ;;
    prune-sessions) shift; cmd_prune_sessions "$@" ;;
    cull)    shift; cmd_cull "$@" ;;
    bridge)  shift; cmd_bridge "$@" ;;
    prune-bridges) shift; cmd_prune_bridges "$@" ;;
    cleanup) shift; cmd_cleanup "$@" ;;
    status)  shift; cmd_status "$@" ;;
    help|-h|--help) shift || true; cmd_help "$@" ;;
    *)       die "unknown command: $1" ;;
esac
